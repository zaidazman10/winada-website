---
import Layout from '../layouts/Layout.astro';
import BrandHeader from '../components/BrandHeader.astro';
import Hero from '../components/Hero.astro';
import PagingOverride from '../components/Infographics/PagingOverride.astro';
import ZoneRouting from '../components/Infographics/ZoneRouting.astro';
import SmartControl from '../components/Infographics/SmartControl.astro';
import PremiumFeatures from '../components/PremiumFeatures.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <BrandHeader />
  <main>
    <Hero />
    
    <section id="concept" class="section container">
      <div class="text-center" style="margin-bottom: 60px;">
        <h2 style="font-size: clamp(2.5rem, 5vw, 3.5rem); margin-bottom: 16px;">How It Works</h2>
        <p style="font-size: 1.25rem; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto;">
          A complete, intelligent audio solution for your entire space.
        </p>
      </div>

      <div class="infographics-container">
        <PagingOverride />
        <ZoneRouting />
        <SmartControl />
      </div>
    </section>

    <PremiumFeatures />
    <Contact />
  </main>
  <Footer />
</Layout>
