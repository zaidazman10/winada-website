---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Winada | Premium Audio Controller",
  description = "The central hub for your music. Seamlessly control inputs, volumes, and zones across your entire space."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Using Inter to mimic San Francisco -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Three.js for 3D Background -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <title>{title}</title>
  </head>
  <body class="bg-black text-white selection:bg-cyan-500 selection:text-black">
    <!-- WebGL Background -->
    <canvas id="webgl-canvas" class="fixed inset-0 w-full h-full -z-20"></canvas>
    
    <!-- Protective Dark Overlay for Text Legibility -->
    <div class="fixed inset-0 w-full h-full bg-gradient-to-b from-black/80 via-black/40 to-black/90 pointer-events-none -z-10"></div>
    
    <div class="relative z-10 w-full min-h-screen">
      <slot />
    </div>

    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof THREE === 'undefined') return;

        const canvas = document.getElementById('webgl-canvas');
        if (!canvas) return;

        const isMobile = window.innerWidth < 768;
        const renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(isMobile ? 1 : Math.min(window.devicePixelRatio, 1.5));

        const scene = new THREE.Scene();
        // Orthographic camera for full screen 2D shader rendering
        const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
        const geometry = new THREE.PlaneGeometry(2, 2);

        const fragmentShader = `
          uniform float uTime;
          uniform vec2 uResolution;

          float random(in vec2 st) {
              return fract(sin(dot(st.xy, vec2(12.9898,78.233))) * 43758.5453123);
          }

          float noise(in vec2 st) {
              vec2 i = floor(st);
              vec2 f = fract(st);
              float a = random(i);
              float b = random(i + vec2(1.0, 0.0));
              float c = random(i + vec2(0.0, 1.0));
              float d = random(i + vec2(1.0, 1.0));
              vec2 u = f * f * (3.0 - 2.0 * f);
              return mix(a, b, u.x) + (c - a)* u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
          }

          // Optimized fBM for mobile (3 loops instead of 5)
          float fbm(in vec2 st) {
              float value = 0.0;
              float amplitude = 0.5;
              vec2 shift = vec2(100.0);
              mat2 rot = mat2(cos(0.5), sin(0.5), -sin(0.5), cos(0.5));
              for (int i = 0; i < 3; ++i) {
                  value += amplitude * noise(st);
                  st = rot * st * 2.0 + shift;
                  amplitude *= 0.5;
              }
              return value;
          }

          void main() {
              vec2 st = gl_FragCoord.xy / uResolution.xy;
              st.x *= uResolution.x / uResolution.y;

              vec3 color = vec3(0.0);

              vec2 q = vec2(0.);
              q.x = fbm( st + 0.00 * uTime);
              q.y = fbm( st + vec2(1.0));

              vec2 r = vec2(0.);
              r.x = fbm( st + 1.0 * q + vec2(1.7,9.2) + 0.15 * uTime );
              r.y = fbm( st + 1.0 * q + vec2(8.3,2.8) + 0.126 * uTime );

              float f = fbm(st + r);

              // Minimalist UI/UX Palette: Deep Midnight Blue to subtle Indigo
              color = mix(vec3(0.0, 0.0, 0.02), vec3(0.0, 0.02, 0.06), clamp((f*f)*4.0, 0.0, 1.0));
              color = mix(color, vec3(0.0, 0.1, 0.2), clamp(length(q), 0.0, 1.0)); 
              color = mix(color, vec3(0.05, 0.0, 0.15), clamp(length(r.x), 0.0, 1.0)); 

              gl_FragColor = vec4((f*f*f + 0.6*f*f + 0.5*f) * color, 1.0);
          }
        `;

        const material = new THREE.ShaderMaterial({
          uniforms: {
            uTime: { value: 0 },
            uResolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) }
          },
          vertexShader: `
            void main() {
              gl_Position = vec4(position, 1.0);
            }
          `,
          fragmentShader: fragmentShader,
          transparent: true,
          depthWrite: false
        });

        const mesh = new THREE.Mesh(geometry, material);
        scene.add(mesh);

        // --- 3D Particle System ---
        const particleScene = new THREE.Scene();
        const particleCamera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        particleCamera.position.z = 100;

        // Create soft circle texture for particles to prevent blocky/unrendered look
        const canvasTexture = document.createElement('canvas');
        canvasTexture.width = 32;
        canvasTexture.height = 32;
        const ctx = canvasTexture.getContext('2d');
        const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
        gradient.addColorStop(0, 'rgba(0, 242, 254, 1)');
        gradient.addColorStop(1, 'rgba(0, 242, 254, 0)');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, 32, 32);
        const circleTexture = new THREE.CanvasTexture(canvasTexture);

        // --- Minimalist Audio Soundwave (Particle Sea) ---
        const segmentsX = isMobile ? 120 : 250;
        const segmentsY = isMobile ? 40 : 80;
        // Massive plane spanning far into the distance
        const particleGeometry = new THREE.PlaneGeometry(800, 400, segmentsX, segmentsY);
        particleGeometry.rotateX(-Math.PI / 2); // Lay it flat
        
        // Add random sizes for particles (More uniform for a cleaner look)
        const vertexCount = particleGeometry.attributes.position.count;
        const sizeArray = new Float32Array(vertexCount);
        for(let i = 0; i < vertexCount; i++) {
            sizeArray[i] = Math.random() * 0.5 + 1.2; // Tiny, clean dust particles
        }
        particleGeometry.setAttribute('aSize', new THREE.BufferAttribute(sizeArray, 1));

        const coreVertexShader = `
          attribute float aSize;
          varying vec3 vPosition;

          void main() {
            vec3 pos = position;
            
            // Create a flowing soundwave/ocean ripple using combined sine waves
            float wave1 = sin(pos.x * 0.02 + uTime * 1.5) * 8.0;
            float wave2 = cos(pos.z * 0.03 + uTime * 1.0) * 6.0;
            float wave3 = sin((pos.x + pos.z) * 0.01 + uTime * 0.5) * 12.0;
            
            pos.y += wave1 + wave2 + wave3;
            vPosition = pos;

            vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
            
            gl_PointSize = aSize * (350.0 / -mvPosition.z);
            gl_Position = projectionMatrix * mvPosition;
          }
        `;

        const coreFragmentShader = `
          uniform sampler2D pointTexture;
          varying vec3 vPosition;

          void main() {
            // UI/UX Color Palette: Sleek Cyan and Indigo
            vec3 cyan = vec3(0.0, 0.8, 1.0);
            vec3 indigo = vec3(0.3, 0.0, 1.0);
            
            // Blend based on the wave height (Y position) to make peaks cyan and troughs indigo
            float waveHeight = smoothstep(-15.0, 15.0, vPosition.y);
            vec3 color = mix(indigo, cyan, waveHeight);

            // Fade out the particles deeply in the Z-distance so it blends into the background seamlessly
            float distanceFade = smoothstep(150.0, -100.0, vPosition.z);
            
            gl_FragColor = vec4(color, distanceFade * 0.8) * texture2D(pointTexture, gl_PointCoord);
          }
        `;

        const particleMaterial = new THREE.ShaderMaterial({
          uniforms: {
            uTime: { value: 0 },
            pointTexture: { value: circleTexture }
          },
          vertexShader: coreVertexShader,
          fragmentShader: coreFragmentShader,
          transparent: true,
          blending: THREE.AdditiveBlending,
          depthWrite: false
        });
        
        const particlesMesh = new THREE.Points(particleGeometry, particleMaterial);
        // Move the soundwave sea to the bottom of the screen
        particlesMesh.position.y = -60;
        particleScene.add(particlesMesh);

        // Mouse Parallax Interaction
        let mouseX = 0;
        let mouseY = 0;
        window.addEventListener('mousemove', (event) => {
          mouseX = (event.clientX - window.innerWidth / 2) * 0.05;
          mouseY = (event.clientY - window.innerHeight / 2) * 0.05;
        });

        const clock = new THREE.Clock();

        function animate() {
          requestAnimationFrame(animate);
          const time = clock.getElapsedTime();
          material.uniforms.uTime.value = time;
          particleMaterial.uniforms.uTime.value = time;
          
          renderer.autoClear = true;
          renderer.render(scene, camera);

          renderer.clearDepth();

          renderer.autoClear = false;
          
          particleCamera.position.x += (mouseX - particleCamera.position.x) * 0.05;
          particleCamera.position.y += (-mouseY - particleCamera.position.y) * 0.05;
          particleCamera.lookAt(particleScene.position);
          
          renderer.render(particleScene, particleCamera);
        }

        animate();

        window.addEventListener('resize', () => {
          const mobile = window.innerWidth < 768;
          renderer.setPixelRatio(mobile ? 1 : Math.min(window.devicePixelRatio, 1.5));
          renderer.setSize(window.innerWidth, window.innerHeight);
          material.uniforms.uResolution.value.set(window.innerWidth, window.innerHeight);
          
          particleCamera.aspect = window.innerWidth / window.innerHeight;
          particleCamera.updateProjectionMatrix();
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ===== Futuristic Dark Aurora Design System ===== */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Dark Mode Palette */
    --color-bg-base: #000000;
    --color-bg-alt: rgba(255, 255, 255, 0.03);
    --color-surface: rgba(255, 255, 255, 0.05);
    
    /* Text */
    --color-text-primary: #ffffff;
    --color-text-secondary: #a1a1a6;
    --color-text-tertiary: #6e6e73;
    
    /* Accents */
    --color-accent-blue: #00f2fe;
    --color-accent-blue-hover: #4facfe;

    /* Borders */
    --color-border: rgba(255, 255, 255, 0.1);

    /* Typography */
    --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;

    /* Layout */
    --container-max-width: 980px;
    --section-padding: clamp(80px, 12vw, 160px);
    
    /* Animations */
    --transition-snappy: 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    --transition-smooth: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: var(--color-bg-base);
    color: var(--color-text-primary);
  }

  body {
    font-family: var(--font-primary);
    font-size: 17px;
    line-height: 1.47059;
    font-weight: 400;
    letter-spacing: -0.022em;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }

  /* WebGL Background System */
  #webgl-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    background: #000000;
    pointer-events: none;
  }

  .app-wrapper {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .container {
    width: 100%;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: var(--section-padding) 0;
  }

  /* Typography */
  h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.015em;
  }

  /* Glassmorphic Hardware Style Cards */
  .hardware-panel {
    background: rgba(20, 20, 25, 0.4);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-blue);
    color: #ffffff;
    padding: 12px 24px;
    font-size: 17px;
    font-weight: 400;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-snappy);
    border: none;
  }

  .btn-primary:hover {
    background: var(--color-accent-blue-hover);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.05);
    color: var(--color-text-primary);
    padding: 12px 24px;
    font-size: 17px;
    font-weight: 400;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-snappy);
    border: none;
  }

  .btn-secondary:hover {
    background: rgba(0,0,0,0.08);
  }

  /* Animations */
  .fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(30px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg-base);
  }
  ::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 5px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
  }
</style>
