---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Winada | Premium Audio Controller",
  description = "The central hub for your music. Seamlessly control inputs, volumes, and zones across your entire space."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Using Inter to mimic San Francisco -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Three.js for 3D Background -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <title>{title}</title>
  </head>
  <body>
    <!-- 3D WebGL Background -->
    <canvas id="webgl-canvas"></canvas>

    <div class="app-wrapper">
      <slot />
    </div>

    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof THREE === 'undefined') return;

        const canvas = document.getElementById('webgl-canvas');
        if (!canvas) return;

        const renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        const scene = new THREE.Scene();
        // Orthographic camera for full screen 2D shader rendering
        const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
        const geometry = new THREE.PlaneGeometry(2, 2);

        const fragmentShader = `
          uniform float uTime;
          uniform vec2 uResolution;

          // Hash function for noise
          float random(in vec2 st) {
              return fract(sin(dot(st.xy, vec2(12.9898,78.233))) * 43758.5453123);
          }

          // 2D Noise
          float noise(in vec2 st) {
              vec2 i = floor(st);
              vec2 f = fract(st);

              float a = random(i);
              float b = random(i + vec2(1.0, 0.0));
              float c = random(i + vec2(0.0, 1.0));
              float d = random(i + vec2(1.0, 1.0));

              vec2 u = f * f * (3.0 - 2.0 * f);
              return mix(a, b, u.x) + (c - a)* u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
          }

          // Fractal Brownian Motion
          float fbm(in vec2 st) {
              float value = 0.0;
              float amplitude = 0.5;
              vec2 shift = vec2(100.0);
              // Rotate to create swirling effect
              mat2 rot = mat2(cos(0.5), sin(0.5), -sin(0.5), cos(0.5));
              for (int i = 0; i < 5; ++i) {
                  value += amplitude * noise(st);
                  st = rot * st * 2.0 + shift;
                  amplitude *= 0.5;
              }
              return value;
          }

          void main() {
              vec2 st = gl_FragCoord.xy / uResolution.xy;
              // Fix aspect ratio
              st.x *= uResolution.x / uResolution.y;

              vec3 color = vec3(0.0);

              // Fluid distortion layers
              vec2 q = vec2(0.);
              q.x = fbm( st + 0.00 * uTime);
              q.y = fbm( st + vec2(1.0));

              vec2 r = vec2(0.);
              r.x = fbm( st + 1.0 * q + vec2(1.7,9.2) + 0.15 * uTime );
              r.y = fbm( st + 1.0 * q + vec2(8.3,2.8) + 0.126 * uTime );

              float f = fbm(st + r);

              // Dark fluid colors: Deep space background
              color = mix(vec3(0.0, 0.0, 0.02),
                          vec3(0.0, 0.1, 0.2),
                          clamp((f*f)*4.0, 0.0, 1.0));

              // Swirling Neon Cyan and Blue
              color = mix(color,
                          vec3(0.0, 0.7, 1.0),
                          clamp(length(q), 0.0, 1.0));

              // Swirling Deep Violet / Magenta
              color = mix(color,
                          vec3(0.4, 0.0, 0.8),
                          clamp(length(r.x), 0.0, 1.0));

              // Soften the contrast and apply darkness
              gl_FragColor = vec4((f*f*f + 0.6*f*f + 0.5*f) * color, 1.0);
          }
        `;

        const material = new THREE.ShaderMaterial({
          uniforms: {
            uTime: { value: 0 },
            uResolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) }
          },
          vertexShader: `
            void main() {
              gl_Position = vec4(position, 1.0);
            }
          `,
          fragmentShader: fragmentShader,
          transparent: true,
          depthWrite: false
        });

        const mesh = new THREE.Mesh(geometry, material);
        scene.add(mesh);

        // --- 3D Particle System ---
        const particleScene = new THREE.Scene();
        const particleCamera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        particleCamera.position.z = 100;

        const particleCount = 2000;
        const posArray = new Float32Array(particleCount * 3);
        for(let i = 0; i < particleCount * 3; i++) {
          posArray[i] = (Math.random() - 0.5) * 500;
        }
        const particleGeometry = new THREE.BufferGeometry();
        particleGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
        
        const particleMaterial = new THREE.PointsMaterial({
          size: 1.5,
          color: 0x00f2fe, // Neon cyan
          transparent: true,
          opacity: 0.5,
          blending: THREE.AdditiveBlending
        });
        
        const particlesMesh = new THREE.Points(particleGeometry, particleMaterial);
        particleScene.add(particlesMesh);

        // --- Lights for Glass ---
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
        particleScene.add(ambientLight);
        
        const dirLight = new THREE.DirectionalLight(0x00f2fe, 3);
        dirLight.position.set(50, 50, 50);
        particleScene.add(dirLight);

        const dirLight2 = new THREE.DirectionalLight(0xfa709a, 2);
        dirLight2.position.set(-50, -50, 50);
        particleScene.add(dirLight2);

        // --- Floating Crystal Geometry ---
        const glassMat = new THREE.MeshPhongMaterial({
          color: 0x00f2fe,
          emissive: 0x002255,
          specular: 0xffffff,
          shininess: 100,
          transparent: true,
          opacity: 0.4,
          wireframe: true
        });
        
        const glassMesh1 = new THREE.Mesh(new THREE.IcosahedronGeometry(25, 0), glassMat);
        glassMesh1.position.set(-45, 20, 10);
        particleScene.add(glassMesh1);

        const glassMesh2 = new THREE.Mesh(new THREE.OctahedronGeometry(20, 0), glassMat);
        glassMesh2.position.set(50, -20, 0);
        particleScene.add(glassMesh2);

        // --- High-Speed Data Streams ---
        const streams = [];
        const streamGeo = new THREE.CylinderGeometry(0.8, 0.8, 100, 4);
        streamGeo.rotateX(Math.PI / 2); // point them along Z axis
        
        for(let i = 0; i < 20; i++) {
          // Mix of cyan and violet streams
          const streamMat = new THREE.MeshBasicMaterial({ 
            color: Math.random() > 0.5 ? 0x00f2fe : 0xfa709a, 
            transparent: true, 
            opacity: 0.6 
          });
          const stream = new THREE.Mesh(streamGeo, streamMat);
          stream.position.set(
            (Math.random() - 0.5) * 300,
            (Math.random() - 0.5) * 300,
            (Math.random() - 0.5) * 300
          );
          // Fast Z velocity
          stream.velocity = new THREE.Vector3(0, 0, Math.random() * 3 + 2);
          particleScene.add(stream);
          streams.push(stream);
        }

        // Mouse Parallax Interaction
        let mouseX = 0;
        let mouseY = 0;
        window.addEventListener('mousemove', (event) => {
          mouseX = (event.clientX - window.innerWidth / 2) * 0.05;
          mouseY = (event.clientY - window.innerHeight / 2) * 0.05;
        });

        const clock = new THREE.Clock();

        function animate() {
          requestAnimationFrame(animate);
          material.uniforms.uTime.value = clock.getElapsedTime();
          
          // Render Background Liquid Shader
          renderer.autoClear = true;
          renderer.render(scene, camera);

          // Fix Depth Occlusion: Clear depth buffer so the 2D background quad doesn't hide 3D objects
          renderer.clearDepth();

          // Render 3D Foreground Particles
          renderer.autoClear = false;
          
          // Slowly rotate entire particle field
          particlesMesh.rotation.y += 0.001;
          particlesMesh.rotation.x += 0.0005;

          // Animate Glass Geometry
          glassMesh1.rotation.x += 0.002;
          glassMesh1.rotation.y += 0.003;
          glassMesh2.rotation.x -= 0.003;
          glassMesh2.rotation.z -= 0.002;
          // Gentle floating motion
          glassMesh1.position.y += Math.sin(material.uniforms.uTime.value) * 0.02;
          glassMesh2.position.y += Math.cos(material.uniforms.uTime.value) * 0.02;

          // Animate Data Streams
          for(let i = 0; i < streams.length; i++) {
            const stream = streams[i];
            stream.position.add(stream.velocity);
            // Reset if they fly past the camera
            if (stream.position.z > 150) {
              stream.position.z = -200;
              stream.position.x = (Math.random() - 0.5) * 300;
              stream.position.y = (Math.random() - 0.5) * 300;
            }
          }
          
          // Smooth camera parallax based on mouse
          particleCamera.position.x += (mouseX - particleCamera.position.x) * 0.05;
          particleCamera.position.y += (-mouseY - particleCamera.position.y) * 0.05;
          particleCamera.lookAt(particleScene.position);
          
          renderer.render(particleScene, particleCamera);
        }

        animate();

        window.addEventListener('resize', () => {
          renderer.setSize(window.innerWidth, window.innerHeight);
          material.uniforms.uResolution.value.set(window.innerWidth, window.innerHeight);
          
          particleCamera.aspect = window.innerWidth / window.innerHeight;
          particleCamera.updateProjectionMatrix();
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ===== Futuristic Dark Aurora Design System ===== */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Dark Mode Palette */
    --color-bg-base: #000000;
    --color-bg-alt: rgba(255, 255, 255, 0.03);
    --color-surface: rgba(255, 255, 255, 0.05);
    
    /* Text */
    --color-text-primary: #ffffff;
    --color-text-secondary: #a1a1a6;
    --color-text-tertiary: #6e6e73;
    
    /* Accents */
    --color-accent-blue: #00f2fe;
    --color-accent-blue-hover: #4facfe;

    /* Borders */
    --color-border: rgba(255, 255, 255, 0.1);

    /* Typography */
    --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;

    /* Layout */
    --container-max-width: 980px;
    --section-padding: clamp(80px, 12vw, 160px);
    
    /* Animations */
    --transition-snappy: 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    --transition-smooth: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: var(--color-bg-base);
    color: var(--color-text-primary);
  }

  body {
    font-family: var(--font-primary);
    font-size: 17px;
    line-height: 1.47059;
    font-weight: 400;
    letter-spacing: -0.022em;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }

  /* WebGL Background System */
  #webgl-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    background: #000000;
    pointer-events: none;
  }

  .app-wrapper {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .container {
    width: 100%;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: var(--section-padding) 0;
  }

  /* Typography */
  h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.015em;
  }

  /* Glassmorphic Hardware Style Cards */
  .hardware-panel {
    background: rgba(20, 20, 25, 0.4);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-blue);
    color: #ffffff;
    padding: 12px 24px;
    font-size: 17px;
    font-weight: 400;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-snappy);
    border: none;
  }

  .btn-primary:hover {
    background: var(--color-accent-blue-hover);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.05);
    color: var(--color-text-primary);
    padding: 12px 24px;
    font-size: 17px;
    font-weight: 400;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-snappy);
    border: none;
  }

  .btn-secondary:hover {
    background: rgba(0,0,0,0.08);
  }

  /* Animations */
  .fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(30px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg-base);
  }
  ::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 5px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
  }
</style>
