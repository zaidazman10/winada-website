---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Winada — Simple Multi-Room Music Control",
  description = "A simple, reliable controller for multi-zone and multi-room audio systems in workspaces, restaurants, and homes."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Obsidian Audio Ambient Background -->
    <div class="obsidian-bg">
      <div class="ambient-glows">
        <div class="glow-orb orb-cyan"></div>
        <div class="glow-orb orb-pink"></div>
      </div>
      <div class="dot-grid"></div>
    </div>

    <slot />
  </body>
</html>

<style is:global>
  /* ===== Obsidian Audio Design System ===== */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Deep space colors */
    --color-bg: #090a0f;
    --color-bg-alt: #11131c;
    
    /* Clean high-contrast typography */
    --color-text: #ffffff;
    --color-text-muted: #8b8e9f;
    --color-text-darker: #4a4d61;
    
    /* Neon glowing accents */
    --color-brand: #00f0ff; /* Electric Cyan */
    --color-brand-glow: rgba(0, 240, 255, 0.12);
    
    --color-accent-cyan: #00f0ff;
    --color-accent-pink: #ff007f;
    --color-accent-green: #39ff14;

    /* Glassmorphism border styles */
    --color-border: rgba(255, 255, 255, 0.08);
    --color-border-strong: rgba(255, 255, 255, 0.15);

    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Plus Jakarta Sans', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;

    --container-width: 1040px;
    --transition-smooth: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    overflow-x: hidden;
    position: relative;
  }

  /* Deep Space Ambient Glow Background */
  .obsidian-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: radial-gradient(circle at 50% 50%, #11131e 0%, #090a0f 100%);
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 32px 32px;
    z-index: 1;
    opacity: 0.8;
  }

  .ambient-glows {
    position: absolute;
    inset: 0;
    filter: blur(140px);
    opacity: 0.22;
    z-index: 0;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    animation: drift 22s infinite alternate ease-in-out;
  }

  .orb-cyan {
    width: 650px;
    height: 650px;
    background: radial-gradient(circle, rgba(0, 240, 255, 0.35) 0%, transparent 75%);
    top: -20%;
    left: -10%;
  }

  .orb-pink {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 0, 127, 0.25) 0%, transparent 75%);
    bottom: -15%;
    right: -10%;
    animation-delay: -6s;
  }

  @keyframes drift {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -40px) scale(1.08); }
    100% { transform: translate(-20px, 30px) scale(0.95); }
  }

  .container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 600px) {
    .container {
      padding: 0 16px;
    }
  }

  .section {
    padding: 80px 0;
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 600px) {
    .section {
      padding: 56px 0;
    }
  }

  .meta-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 1.5px;
    color: var(--color-brand);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
    background: rgba(255, 255, 255, 0.03);
    padding: 6px 12px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: 18px;
  }

  .section-desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    font-weight: 400;
    max-width: 620px;
    line-height: 1.6;
  }

  /* Form Elements - Glassmorphism */
  input, select, textarea {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 14px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    outline: none;
    transition: all var(--transition-smooth);
    width: 100%;
    border-radius: 8px;
  }

  input:focus, select:focus, textarea:focus {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--color-brand);
    box-shadow: 0 0 16px var(--color-brand-glow);
  }

  button {
    background: #ffffff;
    color: #090a0f;
    border: 1px solid #ffffff;
    padding: 14px 28px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all var(--transition-smooth);
    border-radius: 8px;
  }

  button:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #ffffff;
    box-shadow: 0 0 24px var(--color-brand-glow);
  }

  /* Glassmorphism Card Style */
  .brand-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    padding: 32px;
    border-radius: 16px;
    position: relative;
    transition: all var(--transition-smooth);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
  }

  .brand-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-text-darker);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }
</style>
