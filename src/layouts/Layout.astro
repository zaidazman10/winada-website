---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Winada — Multizone Audio Controller",
  description = "A professional, low-latency multi-zone audio controller and distribution core."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Blueprint Dot Grid and Soft Ambient Background -->
    <div class="blueprint-bg">
      <div class="dot-grid"></div>
      <div class="ambient-glows">
        <div class="glow-orb orb-apricot"></div>
        <div class="glow-orb orb-blue"></div>
      </div>
    </div>

    <slot />
  </body>
</html>

<style is:global>
  /* ===== Minimalist Blueprint Design System ===== */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Pure plaster white & cool clay base */
    --color-bg: #fcfcfb;
    --color-bg-alt: #f5f5f3;
    
    /* Deep carbon black */
    --color-text: #121315;
    --color-text-muted: #5a5d64;
    --color-text-darker: #9ea2aa;
    
    /* Architectural accents */
    --color-brand: #e28a42; /* Warm Copper */
    --color-brand-glow: rgba(226, 138, 66, 0.06);
    
    /* Clean zone colors */
    --color-zone-1: #e28a42; /* Copper Orange */
    --color-zone-2: #2563eb; /* Cobalt Blue */
    --color-zone-3: #0891b2; /* Deep Teal */
    --color-zone-4: #4f46e5; /* Indigo */
    --color-zone-5: #475569; /* Steel Slate */

    --color-border: rgba(18, 19, 21, 0.04);
    --color-border-strong: rgba(18, 19, 21, 0.08);

    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Plus Jakarta Sans', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;

    --container-width: 1040px;
    --transition-smooth: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    overflow-x: hidden;
    position: relative;
  }

  /* Dot Grid and Ambient Orbs Background */
  .blueprint-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(18, 19, 21, 0.03) 1.2px, transparent 1.2px);
    background-size: 24px 24px;
    z-index: 1;
  }

  .ambient-glows {
    position: absolute;
    inset: 0;
    filter: blur(150px);
    opacity: 0.18;
    z-index: 0;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    animation: drift 25s infinite alternate ease-in-out;
  }

  .orb-apricot {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(226, 138, 66, 0.35) 0%, transparent 75%);
    top: -15%;
    left: -5%;
  }

  .orb-blue {
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.25) 0%, transparent 75%);
    bottom: -15%;
    right: -5%;
    animation-delay: -8s;
  }

  @keyframes drift {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(50px, -30px) scale(1.1); }
    100% { transform: translate(-30px, 50px) scale(0.95); }
  }

  .container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 600px) {
    .container {
      padding: 0 16px;
    }
  }

  .section {
    padding: 64px 0;
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 600px) {
    .section {
      padding: 48px 0;
    }
  }

  .meta-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 1.5px;
    color: var(--color-brand);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
    background: var(--color-bg-alt);
    padding: 4px 10px;
    border: 1px solid var(--color-border-strong);
    border-radius: 2px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 300;
    max-width: 580px;
    line-height: 1.6;
  }

  /* Form Elements */
  input, select, textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
    padding: 12px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    outline: none;
    transition: all var(--transition-smooth);
    width: 100%;
    border-radius: 4px;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px var(--color-brand-glow);
  }

  button {
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
    padding: 14px 28px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--transition-smooth);
    border-radius: 4px;
  }

  button:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .brand-card {
    background: rgba(252, 252, 251, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border-strong);
    padding: 28px;
    border-radius: 12px;
    position: relative;
    transition: all var(--transition-smooth);
  }

  .brand-card:hover {
    border-color: var(--color-brand);
    background: rgba(252, 252, 251, 0.95);
    transform: translateY(-2px);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 4px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-text-darker);
  }
</style>
