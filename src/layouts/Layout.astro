---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Winada | Premium Audio Controller",
  description = "The central hub for your music. Seamlessly control inputs, volumes, and zones across your entire space."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Using Inter to mimic San Francisco -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Three.js for 3D Background -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <title>{title}</title>
  </head>
  <body>
    <!-- 3D WebGL Background -->
    <canvas id="webgl-canvas"></canvas>

    <div class="app-wrapper">
      <slot />
    </div>

    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof THREE === 'undefined') return;

        const canvas = document.getElementById('webgl-canvas');
        if (!canvas) return;

        const scene = new THREE.Scene();
        // Fog to blend smoothly into the dark background
        scene.fog = new THREE.FogExp2(0x000000, 0.003);

        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.y = 8;
        camera.position.z = 20;
        camera.rotation.x = -0.2;

        const renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        // Create the terrain grid
        const geometry = new THREE.PlaneGeometry(200, 200, 60, 60);

        // Move the complex math to the GPU via ShaderMaterial for perfect 60fps performance
        const material = new THREE.ShaderMaterial({
          uniforms: {
            uTime: { value: 0 }
          },
          vertexShader: `
            uniform float uTime;
            void main() {
              vec3 pos = position;
              // Add a flying effect directly into the time coordinate to avoid snapping
              float flyingY = pos.y + (uTime * 15.0);
              
              pos.z = sin(pos.x * 0.1 + uTime * 0.6) * 1.5 + 
                      cos(flyingY * 0.1 + uTime * 0.4) * 1.5 +
                      sin((pos.x + flyingY) * 0.05 - uTime * 0.3) * 1.0;
                      
              gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
            }
          `,
          fragmentShader: `
            void main() {
              // Neon cyan color with slight transparency
              gl_FragColor = vec4(0.0, 0.95, 1.0, 0.25);
            }
          `,
          wireframe: true,
          transparent: true
        });

        const plane = new THREE.Mesh(geometry, material);
        plane.rotation.x = -Math.PI / 2;
        plane.position.y = -5;
        scene.add(plane);

        const clock = new THREE.Clock();

        function animate() {
          requestAnimationFrame(animate);
          
          // Only update the time uniform. Zero CPU math = zero lag.
          material.uniforms.uTime.value = clock.getElapsedTime();

          renderer.render(scene, camera);
        }

        animate();

        // Responsive handling
        window.addEventListener('resize', () => {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(window.innerWidth, window.innerHeight);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ===== Futuristic Dark Aurora Design System ===== */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Dark Mode Palette */
    --color-bg-base: #000000;
    --color-bg-alt: rgba(255, 255, 255, 0.03);
    --color-surface: rgba(255, 255, 255, 0.05);
    
    /* Text */
    --color-text-primary: #ffffff;
    --color-text-secondary: #a1a1a6;
    --color-text-tertiary: #6e6e73;
    
    /* Accents */
    --color-accent-blue: #00f2fe;
    --color-accent-blue-hover: #4facfe;

    /* Borders */
    --color-border: rgba(255, 255, 255, 0.1);

    /* Typography */
    --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;

    /* Layout */
    --container-max-width: 980px;
    --section-padding: clamp(80px, 12vw, 160px);
    
    /* Animations */
    --transition-snappy: 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    --transition-smooth: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: var(--color-bg-base);
    color: var(--color-text-primary);
  }

  body {
    font-family: var(--font-primary);
    font-size: 17px;
    line-height: 1.47059;
    font-weight: 400;
    letter-spacing: -0.022em;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }

  /* WebGL Background System */
  #webgl-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    background: #000000;
    pointer-events: none;
  }

  .app-wrapper {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .container {
    width: 100%;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: var(--section-padding) 0;
  }

  /* Typography */
  h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.015em;
  }

  /* Glassmorphic Hardware Style Cards */
  .hardware-panel {
    background: rgba(20, 20, 25, 0.4);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-blue);
    color: #ffffff;
    padding: 12px 24px;
    font-size: 17px;
    font-weight: 400;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-snappy);
    border: none;
  }

  .btn-primary:hover {
    background: var(--color-accent-blue-hover);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.05);
    color: var(--color-text-primary);
    padding: 12px 24px;
    font-size: 17px;
    font-weight: 400;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-snappy);
    border: none;
  }

  .btn-secondary:hover {
    background: rgba(0,0,0,0.08);
  }

  /* Animations */
  .fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(30px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg-base);
  }
  ::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 5px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
  }
</style>
