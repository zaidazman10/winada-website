---
// BrandHeader - Floating glass navigation bar
---

<header class="brand-header">
  <div class="container">
    <div class="navbar-glass">
      <a href="/" class="brand-logo">
        <!-- Fluid bezier soundwave gradient logo mark -->
        <svg class="logo-mark" viewBox="0 0 40 40" fill="none">
          <defs>
            <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="var(--color-accent-cyan)" />
              <stop offset="100%" stop-color="var(--color-accent-pink)" />
            </linearGradient>
          </defs>
          <path 
            d="M 6 18 C 10 5, 14 35, 18 20 C 22 5, 26 35, 34 18" 
            stroke="url(#logo-grad)" 
            stroke-width="3.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          />
        </svg>
        <span class="brand-name">winada <span class="brand-product">controller</span></span>
      </a>

      <nav class="nav-links">
        <a href="#" class="nav-link">overview</a>
        <a href="#datasheet" class="nav-link">features</a>
        <a href="#contact" class="nav-link">contact</a>
      </nav>

      <a href="#contact" class="nav-cta">Get Started</a>
    </div>
  </div>
</header>

<style>
  .brand-header {
    position: fixed;
    top: 24px;
    left: 0;
    right: 0;
    z-index: 100;
  }

  @media (max-width: 600px) {
    .brand-header {
      top: 12px;
    }
  }

  .navbar-glass {
    background: rgba(9, 10, 15, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--color-border);
    padding: 10px 24px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo-mark {
    width: 28px;
    height: 28px;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    text-transform: lowercase;
  }

  .brand-product {
    font-weight: 300;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-left: 1px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-smooth);
    text-transform: capitalize;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-cta {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text);
    border: 1px solid var(--color-border-strong);
    padding: 8px 16px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: all var(--transition-smooth);
  }

  .nav-cta:hover {
    background: #ffffff;
    color: #090a0f;
    box-shadow: 0 0 16px rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }
</style>
