---
// BrandHeader - Clean, minimalist header featuring the Winada logo and wordmark
---

<header class="brand-header">
  <div class="container header-inner">
    <a href="/" class="brand-logo">
      <!-- Geometric W ribbon soundwave logo mark -->
      <svg class="logo-mark" viewBox="0 0 40 40" fill="none">
        <path 
          d="M 6 10 L 14 30 L 20 18 L 26 30 L 34 10" 
          stroke="var(--color-brand)" 
          stroke-width="3" 
          stroke-linecap="round" 
          stroke-linejoin="round"
        />
        <!-- Accent indicator dot -->
        <circle cx="34" cy="10" r="2.5" fill="var(--color-brand)" />
      </svg>
      <span class="brand-name">winada <span class="brand-product">multizone audio</span></span>
    </a>
  </div>
</header>

<style>
  .brand-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 32px 0;
    z-index: 10;
  }

  @media (max-width: 600px) {
    .brand-header {
      padding: 16px 0;
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo-mark {
    width: 32px;
    height: 32px;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    text-transform: lowercase;
  }

  .brand-product {
    font-weight: 300;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-left: 2px;
  }
</style>
