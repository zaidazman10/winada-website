---
---

<header class="header">
  <div class="container header-inner">
    <a href="/winada-website/" class="brand">
      <div class="brand-logo">WINADA</div>
    </a>

    <nav class="nav-links">
      <a href="#concept">How it works</a>
      <a href="#features">Features</a>
      <a href="#contact" class="btn-primary btn-small">Get a Quote</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(10, 10, 15, 0.6);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px; /* Apple uses shorter navs often */
  }

  .brand {
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .brand-logo {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links a:not(.btn-primary) {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 400;
    transition: color var(--transition-snappy);
  }

  .nav-links a:not(.btn-primary):hover {
    color: var(--color-text-primary);
  }

  .btn-small {
    padding: 6px 14px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .nav-links {
      gap: 16px;
    }
    .nav-links a:not(.btn-primary) {
      display: none;
    }
  }
</style>
