---
// Features - Bento layout showing capabilities, followed by a detailed technical datasheet
const capabilities = [
  {
    num: "01",
    title: "Perfect Room Sync",
    desc: "Listen to music across multiple rooms with zero delay. Sound stays perfectly in sync as you walk from one area to another, with no echo."
  },
  {
    num: "02",
    title: "Voice Broadcasts",
    desc: "Need to make an announcement? Send voice alerts instantly. The music automatically fades down, plays your announcement, and smoothly fades back in."
  },
  {
    num: "03",
    title: "All Your Music Sources",
    desc: "Play Spotify Connect, local music files, or internet radio streams. Easily route any music source to any combination of rooms."
  },
  {
    num: "04",
    title: "Secure Control",
    desc: "Lock volume and room settings using a secure PIN to prevent unauthorized changes. Auto-recovery tools make sure the system stays online 24/7."
  }
];

const technicalSpecs = [
  { category: "System Performance", items: [
    { label: "Room Sync Delay", value: "Less than 0.8ms (perfectly sync'd)" },
    { label: "Audio Quality", value: "High-resolution 24-bit / 192kHz sound" },
    { label: "Network Impact", value: "Lightweight, optimized data streaming" },
    { label: "Play Delay", value: "Instant, responsive channel switching" }
  ]},
  { category: "Supported Audio", items: [
    { label: "Streaming Apps", value: "Spotify Connect, AirPlay 2, local media servers" },
    { label: "Physical Inputs", value: "Audio line-in ports, analog player adapters" },
    { label: "Internet Radio", value: "Online Shoutcast and Icecast web streams" },
    { label: "Intercom Inputs", value: "Microphone lines, office intercom paging feeds" }
  ]},
  { category: "Control & Security", items: [
    { label: "Smart Integrations", value: "Developer HTTP APIs and system triggers" },
    { label: "User Control", value: "Local web controller dashboards, wall panels" },
    { label: "Security Gate", value: "Admin PIN lock and session validation" },
    { label: "System Stability", value: "Auto-restart watchdogs to prevent dropouts" }
  ]}
];
---

<section class="section" id="features">
  <div class="container spec-container">
    
    <!-- Capabilities Bento Layout -->
    <div class="capabilities-section">
      <h2 class="section-title">Built for seamless listening.</h2>
      
      <div class="bento-grid">
        {capabilities.map((cap, i) => (
          <div class="brand-card bento-cell" id={`bento-${i}`}>
            
            <!-- Custom background brand logo watermark -->
            <div class="card-brand-watermark">
              <svg viewBox="0 0 100 100" fill="none">
                <path d="M 15 25 L 35 75 L 50 45 L 65 75 L 85 25" stroke="rgba(226, 138, 66, 0.025)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>

            <div class="bento-top">
              <span class="cell-index">[{cap.num}]</span>
              <h3 class="cell-title">{cap.title}</h3>
              <p class="cell-desc">{cap.desc}</p>
            </div>
            
            {/* Infographics: Clean static/subtle CSS animations in blueprint style */}
            {i === 2 && (
              <div class="mini-equalizer">
                <span class="eq-bar" style="--h: 18px; --delay: 0.1s"></span>
                <span class="eq-bar" style="--h: 30px; --delay: 0.4s"></span>
                <span class="eq-bar" style="--h: 12px; --delay: 0.2s"></span>
                <span class="eq-bar" style="--h: 24px; --delay: 0.5s"></span>
                <span class="eq-bar" style="--h: 8px; --delay: 0.3s"></span>
              </div>
            )}

            {i === 0 && (
              <div class="mini-lock-gauge">
                <span class="gauge-ring"></span>
                <span class="gauge-text">SYNC LOCK ACTIVE</span>
              </div>
            )}

            {i === 1 && (
              <div class="mini-pulse-flow">
                <span class="pulse-line"></span>
                <span class="pulse-wave"></span>
              </div>
            )}

            {i === 3 && (
              <div class="mini-sec-shield">
                <span class="shield-indicator">PIN ACTIVE [****]</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Technical Specs sheet -->
    <div class="tech-specs-section">
      <h2 class="section-title">Technical specifications.</h2>
      
      <div class="tech-grid">
        {technicalSpecs.map((cat) => (
          <div class="brand-card spec-cat-card">
            <h4 class="cat-title">{cat.category}</h4>
            <ul class="cat-list">
              {cat.items.map((item) => (
                <li class="cat-item">
                  <span class="item-label">{item.label}</span>
                  <span class="item-value">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .spec-container {
    border-top: 1px solid var(--color-border);
    padding-top: 80px;
    display: flex;
    flex-direction: column;
    gap: 100px;
  }

  .capabilities-section, .tech-specs-section {
    display: flex;
    flex-direction: column;
  }

  /* Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .bento-cell {
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 240px;
    overflow: hidden;
  }

  /* W Ribbon watermark */
  .card-brand-watermark {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 120px;
    height: 120px;
    pointer-events: none;
    z-index: 0;
  }

  .bento-top {
    position: relative;
    z-index: 1;
  }

  .cell-index {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-brand);
    margin-bottom: 24px;
    display: block;
  }

  .cell-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .cell-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    font-weight: 300;
  }

  /* Mini infographics styled on blueprint layout */
  .mini-equalizer {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 32px;
    margin-top: 24px;
    position: relative;
    z-index: 1;
  }

  .eq-bar {
    width: 3px;
    background: var(--color-brand);
    border-radius: 1px;
    height: var(--h);
    animation: eq-bounce 1s infinite alternate ease-in-out;
    animation-delay: var(--delay);
  }

  .mini-lock-gauge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    position: relative;
    z-index: 1;
  }

  .gauge-ring {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--color-zone-2);
    position: relative;
  }

  .gauge-ring::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px dashed rgba(37, 99, 235, 0.4);
    animation: rot-pulse 8s infinite linear;
  }

  .gauge-text {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.5px;
    color: var(--color-zone-2);
  }

  .mini-pulse-flow {
    width: 100%;
    height: 16px;
    position: relative;
    margin-top: 24px;
    background: rgba(18, 19, 21, 0.02);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    align-items: center;
    z-index: 1;
  }

  .pulse-line {
    position: absolute;
    left: 0;
    width: 0%;
    height: 1px;
    background: var(--color-brand);
    animation: extend-line 3s infinite ease-in-out;
  }

  .pulse-wave {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand);
    animation: move-wave 3s infinite ease-in-out;
  }

  .mini-sec-shield {
    margin-top: 24px;
    background: rgba(18, 19, 21, 0.02);
    padding: 6px 12px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    z-index: 1;
    display: inline-block;
  }

  /* Technical Specs cards layout */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .spec-cat-card {
    padding: 32px;
  }

  .cat-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 12px;
  }

  .cat-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
  }

  .cat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .item-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .item-value {
    font-size: 0.85rem;
    color: var(--color-text);
    font-weight: 300;
    line-height: 1.4;
  }

  @keyframes eq-bounce {
    0% { transform: scaleY(0.3); }
    100% { transform: scaleY(1.3); }
  }

  @keyframes rot-pulse {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes extend-line {
    0%, 100% { width: 0%; left: 0; }
    50% { width: 100%; left: 0; }
    50.1% { width: 100%; left: auto; right: 0; }
    100% { width: 0%; left: auto; right: 0; }
  }

  @keyframes move-wave {
    0% { left: 0%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .tech-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .bento-cell {
      padding: 24px;
      min-height: 200px;
    }
    .spec-cat-card {
      padding: 24px;
    }
    .tech-grid {
      gap: 16px;
    }
    .spec-container {
      gap: 64px;
      padding-top: 48px;
    }
  }
</style>
