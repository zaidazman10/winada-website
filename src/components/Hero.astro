---
// Hero - Branded two-column layout with a floating audio vertex network
---

<section class="hero" id="hero">
  <div class="container hero-container">
    
    <div class="hero-columns">
      <!-- Left Column: Content and Infographic -->
      <div class="hero-left-col">
        <div class="hero-top-row">
          <span class="meta-tag">[ CORE: WINADA.v1 ]</span>
          <span class="meta-tag">[ NETWORK: LOCK ACTIVE ]</span>
        </div>

        <div class="hero-text-block">
          <div class="hero-brand">winada multizone audio</div>
          <h1 class="hero-title">
            Music in every room. Perfect sync.
          </h1>
          <p class="hero-intro">
            Winada lets you play music, stream radio, and make voice announcements across multiple rooms at the same time. It keeps speakers perfectly in sync with zero delay, and makes it easy to control what plays where.
          </p>
        </div>

        <!-- Latency comparison infographic -->
        <div class="hero-specs-infographic">
          <div class="info-grid">
            <div class="info-column">
              <div class="info-label">[ WINADA LATENCY LOCK ]</div>
              <div class="latency-line winada-line">
                <span class="indicator-dot"></span>
              </div>
              <div class="info-value value-teal">&lt; 0.8ms (perfectly sync'd)</div>
            </div>

            <div class="info-column">
              <div class="info-label">[ STANDARD AUDIO ECHO ]</div>
              <div class="latency-line standard-line">
                <span></span><span></span><span></span><span></span><span></span>
              </div>
              <div class="info-value value-orange">~120ms (noticeable delay)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Visual Core with Vertex Network -->
      <div class="hero-right-col">
        <div class="vertex-network-container">
          
          <!-- SVG Vertex audio network -->
          <svg class="vertex-svg" viewBox="0 0 300 300">
            <!-- Connecting lines (Vertices) fanning from W logo at center (150, 150) -->
            <line x1="150" y1="150" x2="60" y2="70" stroke="var(--color-border-strong)" stroke-width="1.5" stroke-dasharray="3 3" />
            <line x1="150" y1="150" x2="240" y2="60" stroke="var(--color-border-strong)" stroke-width="1.5" stroke-dasharray="3 3" />
            <line x1="150" y1="150" x2="250" y2="210" stroke="var(--color-border-strong)" stroke-width="1.5" stroke-dasharray="3 3" />
            <line x1="150" y1="150" x2="60" y2="230" stroke="var(--color-border-strong)" stroke-width="1.5" stroke-dasharray="3 3" />
            <line x1="150" y1="150" x2="150" y2="260" stroke="var(--color-border-strong)" stroke-width="1.5" stroke-dasharray="3 3" />

            <!-- Connecting ring loop -->
            <circle cx="150" cy="150" r="110" fill="none" stroke="var(--color-border)" stroke-width="1.5" />

            <!-- Floating Zone Nodes (Vertices) -->
            <!-- Zone 1 (Coral) -->
            <circle cx="60" cy="70" r="7" fill="var(--color-zone-1)" class="pulse-vertex" />
            <!-- Zone 2 (Sky Blue) -->
            <circle cx="240" cy="60" r="7" fill="var(--color-zone-2)" class="pulse-vertex" />
            <!-- Zone 3 (Fresh Green) -->
            <circle cx="250" cy="210" r="7" fill="var(--color-zone-3)" class="pulse-vertex" />
            <!-- Zone 4 (Amber) -->
            <circle cx="60" cy="230" r="7" fill="var(--color-zone-4)" class="pulse-vertex" />
            <!-- Zone 5 (Rose) -->
            <circle cx="150" cy="260" r="7" fill="var(--color-zone-5)" class="pulse-vertex" />

            <!-- Interactive signal node pulses drifting along vertices -->
            <circle r="3" fill="var(--color-brand)">
              <animateMotion dur="2.5s" repeatCount="indefinite" path="M 150 150 L 60 70" />
            </circle>
            <circle r="3" fill="var(--color-zone-2)">
              <animateMotion dur="3s" begin="0.5s" repeatCount="indefinite" path="M 150 150 L 240 60" />
            </circle>
            <circle r="3" fill="var(--color-zone-3)">
              <animateMotion dur="2.2s" begin="0.8s" repeatCount="indefinite" path="M 150 150 L 250 210" />
            </circle>
            <circle r="3" fill="var(--color-zone-4)">
              <animateMotion dur="2.7s" begin="1.2s" repeatCount="indefinite" path="M 150 150 L 60 230" />
            </circle>
            <circle r="3" fill="var(--color-zone-5)">
              <animateMotion dur="2.4s" begin="0.3s" repeatCount="indefinite" path="M 150 150 L 150 260" />
            </circle>
          </svg>

          <!-- Central Brand W logo hub -->
          <div class="brand-wave-core">
            <svg class="hero-w-logo" viewBox="0 0 100 100" fill="none">
              <path 
                d="M 15 25 L 35 75 L 50 45 L 65 75 L 85 25" 
                stroke="var(--color-brand)" 
                stroke-width="5.5" 
                stroke-linecap="round" 
                stroke-linejoin="round"
                class="w-path-animated"
              />
              <circle cx="85" cy="25" r="4.5" fill="var(--color-brand)" />
            </svg>
            <div class="core-radial-glow"></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 100px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-container {
    width: 100%;
  }

  .hero-columns {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: center;
  }

  .hero-left-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
    text-align: left;
  }

  .hero-top-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .hero-brand {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-brand);
    margin-bottom: 12px;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .hero-intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.6;
  }

  /* Right column: Vertex audio network visual */
  .hero-right-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .vertex-network-container {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vertex-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: visible;
  }

  .pulse-vertex {
    animation: vertex-pulse 2s infinite alternate ease-in-out;
  }
  .pulse-vertex:nth-child(even) {
    animation-delay: 1s;
  }

  .brand-wave-core {
    position: relative;
    z-index: 2;
    width: 130px;
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border-radius: 50%;
    border: 1px solid var(--color-border-strong);
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }

  .hero-w-logo {
    width: 80px;
    height: 80px;
    position: relative;
    z-index: 2;
  }

  .w-path-animated {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: draw-logo 5s ease-in-out infinite alternate;
  }

  .core-radial-glow {
    position: absolute;
    inset: 0px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-brand-glow) 0%, transparent 70%);
    z-index: 1;
    animation: pulse-core 4s infinite alternate ease-in-out;
  }

  /* Latency Infographic */
  .hero-specs-infographic {
    border-top: 1px dashed var(--color-border-strong);
    padding-top: 24px;
    margin-top: 8px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .info-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-darker);
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .latency-line {
    height: 16px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 0 12px;
    margin-bottom: 6px;
  }

  .winada-line::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    height: 1.5px;
    background: #10b981;
    box-shadow: 0 0 4px #10b981;
  }

  .indicator-dot {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #10b981;
    z-index: 2;
    animation: move-pulse 2s infinite linear;
  }

  .standard-line {
    display: flex;
    align-items: center;
    justify-content: space-around;
  }

  .standard-line span {
    width: 2.5px;
    background: var(--color-brand);
    border-radius: 1px;
    animation: scatter-bounce 0.8s infinite alternate;
  }

  .standard-line span:nth-child(1) { height: 8px; animation-delay: 0.1s; }
  .standard-line span:nth-child(2) { height: 4px; animation-delay: 0.4s; }
  .standard-line span:nth-child(3) { height: 11px; animation-delay: 0.2s; }
  .standard-line span:nth-child(4) { height: 6px; animation-delay: 0.3s; }
  .standard-line span:nth-child(5) { height: 9px; animation-delay: 0.5s; }

  .info-value {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
  }

  .value-teal { color: #10b981; }
  .value-orange { color: var(--color-brand); }

  @keyframes draw-logo {
    0% { stroke-dashoffset: 400; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes pulse-core {
    0% { transform: scale(0.95); opacity: 0.6; }
    100% { transform: scale(1.05); opacity: 1; }
  }

  @keyframes vertex-pulse {
    0% { transform: scale(0.85); opacity: 0.8; }
    100% { transform: scale(1.15); opacity: 1; }
  }

  @keyframes move-pulse {
    0% { left: 12px; }
    100% { left: calc(100% - 16px); }
  }

  @keyframes scatter-bounce {
    0% { transform: scaleY(0.4); }
    100% { transform: scaleY(1.4); }
  }

  @media (max-width: 900px) {
    .hero-columns {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-top: 80px;
      padding-bottom: 24px;
      min-height: auto;
    }
    .vertex-network-container {
      width: 260px;
      height: 260px;
      margin: 0 auto;
    }
    .brand-wave-core {
      width: 100px;
      height: 100px;
    }
    .hero-w-logo {
      width: 60px;
      height: 60px;
    }
    .info-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
