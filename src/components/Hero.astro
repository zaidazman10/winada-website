<section class="hero-section container">
  <div class="hero-content fade-in-up">
    <div class="badge">The Smart Audio Switchboard</div>
    <h1 class="hero-title">
      One Controller.<br/>
      <span class="text-gradient">Total Command.</span>
    </h1>
    <p class="hero-subtitle">
      The central hub for your entire multi-room music system. Route any audio source to any room instantly, with absolute clarity and independent volume control.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">Get Your Controller</a>
      <a href="#concept" class="btn-secondary">See How It Works</a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 100px;
  }

  .hero-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .badge {
    background: rgba(0, 240, 255, 0.1);
    color: var(--color-accent-cyan);
    border: 1px solid rgba(0, 240, 255, 0.2);
    padding: 6px 16px;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 0 0 20px rgba(0, 240, 255, 0.05);
  }

  .hero-title {
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-text-primary) 0%, var(--color-text-tertiary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 3vw, 1.375rem);
    color: var(--color-text-secondary);
    max-width: 600px;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
