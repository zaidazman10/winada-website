---
---

<section id="integrations" class="section container">
  <div class="integrations-card hardware-panel fade-in-up">
    <div class="text-center">
      <h2>Seamless Integrations.</h2>
      <p>Winada plays perfectly with the protocols and platforms you already use, creating a truly unified ecosystem.</p>
    </div>

    <div class="logo-grid">
      <div class="logo-item">
        <!-- AirPlay Icon (Placeholder vector style) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21l-8-8h16z"></path><path d="M12 15a8 8 0 0 0 8-8"></path><path d="M12 11a4 4 0 0 0 4-4"></path></svg>
        <span>AirPlay 2</span>
      </div>

      <div class="logo-item">
        <!-- Spotify Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 11.5c2.5-1 5.5-1 8 0"></path><path d="M7 14.5c2.5-1 5.5-1 8 0"></path><path d="M9 17.5c1.5-.5 3.5-.5 5 0"></path></svg>
        <span>Spotify Connect</span>
      </div>

      <div class="logo-item">
        <!-- Dante / Networking Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M2 15h10"></path><path d="M9 18l3-3-3-3"></path></svg>
        <span>Dante Audio</span>
      </div>

      <div class="logo-item">
        <!-- Roon Ready Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon><line x1="12" y1="22" x2="12" y2="15.5"></line><polyline points="22 8.5 12 15.5 2 8.5"></polyline><polyline points="2 15.5 12 8.5 22 15.5"></polyline><line x1="12" y1="2" x2="12" y2="8.5"></line></svg>
        <span>Roon Ready</span>
      </div>
    </div>
  </div>
</section>

<style>
  .integrations-card {
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .text-center {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .text-center h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .text-center p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .logo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .logo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 500px) {
    .logo-grid {
      grid-template-columns: 1fr;
    }
  }

  .logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--color-text-secondary);
    transition: all var(--transition-smooth);
    cursor: pointer;
  }

  .logo-item:hover {
    color: var(--color-accent-blue);
    transform: translateY(-5px);
  }

  .logo-item svg {
    filter: drop-shadow(0 0 10px rgba(0, 242, 254, 0));
    transition: filter var(--transition-smooth);
  }

  .logo-item:hover svg {
    filter: drop-shadow(0 0 15px rgba(0, 242, 254, 0.4));
  }

  .logo-item span {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
</style>
