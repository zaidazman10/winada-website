---
---

<div class="infographic-step">
  <div class="step-content fade-in-up">
    <h3>Plays everything.</h3>
    <p>Plug in your turntable, connect your local server, or stream wirelessly via Wi-Fi and Bluetooth. The Winada Controller accepts all your audio sources effortlessly.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    <div class="hardware-panel plug-board">
      <div class="plug-row">
        <div class="plug-item">
          <div class="plug-port">
            <div class="port-inner"></div>
            <div class="port-label">ANALOG IN</div>
          </div>
          <span class="source-text">Turntables</span>
        </div>
        
        <div class="plug-item">
          <div class="plug-port">
            <div class="port-inner"></div>
            <div class="port-label">OPTICAL</div>
          </div>
          <span class="source-text">TV Audio</span>
        </div>

        <div class="plug-item wireless-item">
          <div class="wireless-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line></svg>
          </div>
          <span class="source-text">Wi-Fi Streaming</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 900px) {
    .infographic-step {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-visual {
    display: flex;
    justify-content: center;
  }

  .plug-board {
    padding: 48px;
    width: 100%;
    background: linear-gradient(145deg, #ffffff 0%, #f5f5f7 100%);
  }

  .plug-row {
    display: flex;
    justify-content: space-around;
    align-items: flex-end;
  }

  .plug-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .plug-port {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #e5e5ea;
    border: 2px solid #d2d2d7;
    box-shadow: inset 0 4px 8px rgba(0,0,0,0.1), 0 2px 4px #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .port-inner {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #1d1d1f;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);
  }

  .port-label {
    position: absolute;
    bottom: -24px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #86868b;
  }

  .wireless-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-blue);
  }

  .source-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin-top: 16px;
  }
</style>
