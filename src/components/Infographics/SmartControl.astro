---
---

<div class="infographic-step">
  <div class="step-content fade-in-up">
    <h3>Effortless control.</h3>
    <p>Everything is managed from a beautifully simple interface. Adjust the volume in the living room, switch the source in the kitchen, or group the whole house together with a tap.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    <div class="tablet-mockup hardware-panel">
      <!-- Camera Dot -->
      <div class="camera-dot"></div>
      
      <!-- App Header -->
      <div class="app-header">
        <span class="app-title">Home Audio</span>
      </div>

      <!-- App Body -->
      <div class="app-body">
        <div class="now-playing">
          <div class="album-art"></div>
          <div class="track-info">
            <h4>Midnight City</h4>
            <p>Spotify Connect</p>
          </div>
        </div>

        <div class="room-list">
          <div class="room-control">
            <div class="rc-header">
              <span class="rc-name">Living Room</span>
              <span class="rc-vol">75%</span>
            </div>
            <div class="apple-slider">
              <div class="slider-fill" style="width: 75%"></div>
            </div>
          </div>

          <div class="room-control">
            <div class="rc-header">
              <span class="rc-name">Kitchen</span>
              <span class="rc-vol">40%</span>
            </div>
            <div class="apple-slider">
              <div class="slider-fill" style="width: 40%"></div>
            </div>
          </div>

          <div class="room-control disabled">
            <div class="rc-header">
              <span class="rc-name">Patio</span>
              <span class="rc-vol">Off</span>
            </div>
            <div class="apple-slider">
              <div class="slider-fill" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 900px) {
    .infographic-step {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-visual {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* Tablet Mockup */
  .tablet-mockup {
    width: 100%;
    max-width: 460px;
    height: 580px;
    background: #ffffff;
    border: 16px solid #f5f5f7;
    border-radius: 24px;
    position: relative;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1), inset 0 0 0 1px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Camera Dot */
  .camera-dot {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -10px);
    width: 6px;
    height: 6px;
    background: #86868b;
    border-radius: 50%;
    z-index: 10;
  }

  .app-header {
    padding: 60px 24px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .app-title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .app-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .now-playing {
    display: flex;
    align-items: center;
    gap: 16px;
    background: #f5f5f7;
    padding: 16px;
    border-radius: 16px;
  }

  .album-art {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%);
    border-radius: 8px;
  }

  .track-info h4 {
    font-size: 1rem;
    font-weight: 600;
  }

  .track-info p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .room-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .room-control {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .room-control.disabled {
    opacity: 0.4;
  }

  .rc-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .rc-vol {
    color: var(--color-text-secondary);
  }

  .apple-slider {
    width: 100%;
    height: 32px;
    background: #f5f5f7;
    border-radius: 16px;
    overflow: hidden;
  }

  .slider-fill {
    height: 100%;
    background: var(--color-accent-blue);
    border-radius: 16px;
  }
</style>
