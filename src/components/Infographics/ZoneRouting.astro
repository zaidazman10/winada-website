---
---

<div class="infographic-step reverse-layout">
  <div class="step-content fade-in-up">
    <h3>Routes anywhere.</h3>
    <p>The Winada Audio Matrix intelligently routes audio across multiple floors and zones. Play ambient music on the ground floor while streaming a podcast to the offices above—all from one highly-engineered central hub.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    
    <div class="data-flow-scene">
      <!-- Left: The Matrix Hardware -->
      <div class="df-matrix hardware-panel">
        <div class="df-matrix-header">
          <span class="df-logo">WINADA CORE</span>
          <div class="df-status">STATUS: ONLINE</div>
        </div>
        <div class="df-ports">
          <div class="df-port-group">
            <div class="df-port active" style="--port-color: #34c759;"></div>
            <div class="df-port-label">Z1</div>
          </div>
          <div class="df-port-group">
            <div class="df-port active" style="--port-color: #007aff;"></div>
            <div class="df-port-label">Z2</div>
          </div>
          <div class="df-port-group">
            <div class="df-port active" style="--port-color: #ff9500;"></div>
            <div class="df-port-label">Z3</div>
          </div>
          <div class="df-port-group">
            <div class="df-port active" style="--port-color: #af52de;"></div>
            <div class="df-port-label">Z4</div>
          </div>
        </div>
      </div>

      <!-- Center: SVG Animated Cables -->
      <div class="df-cables">
        <svg width="100%" height="100%" viewBox="0 0 100 400" preserveAspectRatio="none">
          <!-- Cable 1 (Green) -->
          <path d="M 0,50 C 50,50 50,50 100,50" class="cable-track" />
          <path d="M 0,50 C 50,50 50,50 100,50" class="cable-pulse" style="stroke: #34c759; animation-delay: 0s;" />
          
          <!-- Cable 2 (Blue) -->
          <path d="M 0,150 C 50,150 50,150 100,150" class="cable-track" />
          <path d="M 0,150 C 50,150 50,150 100,150" class="cable-pulse" style="stroke: #007aff; animation-delay: 0.5s;" />

          <!-- Cable 3 (Orange) -->
          <path d="M 0,250 C 50,250 50,250 100,250" class="cable-track" />
          <path d="M 0,250 C 50,250 50,250 100,250" class="cable-pulse" style="stroke: #ff9500; animation-delay: 1s;" />

          <!-- Cable 4 (Purple) -->
          <path d="M 0,350 C 50,350 50,350 100,350" class="cable-track" />
          <path d="M 0,350 C 50,350 50,350 100,350" class="cable-pulse" style="stroke: #af52de; animation-delay: 1.5s;" />
        </svg>
      </div>

      <!-- Right: Room Zones -->
      <div class="df-zones">
        
        <div class="df-room hardware-panel">
          <div class="df-room-icon" style="color: #34c759;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
          </div>
          <div class="df-room-details">
            <span class="df-room-name">Lobby</span>
            <span class="df-room-source">Ambient</span>
          </div>
        </div>

        <div class="df-room hardware-panel">
          <div class="df-room-icon" style="color: #007aff;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
          </div>
          <div class="df-room-details">
            <span class="df-room-name">Patio</span>
            <span class="df-room-source">Spotify</span>
          </div>
        </div>

        <div class="df-room hardware-panel">
          <div class="df-room-icon" style="color: #ff9500;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
          </div>
          <div class="df-room-details">
            <span class="df-room-name">Office</span>
            <span class="df-room-source">Radio</span>
          </div>
        </div>

        <div class="df-room hardware-panel">
          <div class="df-room-icon" style="color: #af52de;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
          </div>
          <div class="df-room-details">
            <span class="df-room-name">Kitchen</span>
            <span class="df-room-source">Podcast</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .reverse-layout {
    grid-template-columns: 1fr 1fr;
  }

  .reverse-layout .step-content {
    grid-column: 2;
    grid-row: 1;
  }
  
  .reverse-layout .step-visual {
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 900px) {
    .infographic-step, .reverse-layout {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
    .reverse-layout .step-content {
      grid-column: 1;
      grid-row: 1;
    }
    .reverse-layout .step-visual {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Animated Data-Flow Schematic */
  .data-flow-scene {
    display: flex;
    align-items: stretch;
    width: 100%;
    max-width: 500px;
    gap: 16px;
    position: relative;
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .data-flow-scene {
      flex-direction: column;
      align-items: center;
    }
  }

  /* Matrix Hardware */
  .df-matrix {
    flex: 0 0 160px;
    background: #1d1d1f;
    border-radius: 16px;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    color: #ffffff;
    z-index: 2;
  }

  @media (max-width: 600px) {
    .df-matrix {
      flex: none;
      width: 100%;
      height: 120px;
      flex-direction: row;
      align-items: center;
      padding: 16px 24px;
    }
  }

  .df-matrix-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .df-logo {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .df-status {
    font-size: 0.65rem;
    color: #34c759;
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .df-ports {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 40px;
  }

  @media (max-width: 600px) {
    .df-ports {
      flex-direction: row;
      margin-top: 0;
    }
  }

  .df-port-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 600px) {
    .df-port-group {
      flex-direction: column;
      gap: 8px;
    }
  }

  .df-port {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #333;
    border: 2px solid #555;
    position: relative;
  }

  .df-port.active {
    background: var(--port-color);
    border-color: var(--port-color);
    box-shadow: 0 0 12px var(--port-color);
  }

  .df-port-label {
    font-size: 0.75rem;
    color: #86868b;
    font-weight: 600;
  }

  /* SVG Cables */
  .df-cables {
    flex: 1;
    min-width: 60px;
    position: relative;
  }

  @media (max-width: 600px) {
    .df-cables {
      width: 100%;
      height: 60px;
      transform: rotate(90deg);
      margin: 20px 0;
    }
  }

  .cable-track {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 4px;
    stroke-dasharray: 8 8;
  }

  .cable-pulse {
    fill: none;
    stroke-width: 6px;
    stroke-linecap: round;
    stroke-dasharray: 20 200;
    animation: flowPulse 2s linear infinite;
  }

  @keyframes flowPulse {
    0% { stroke-dashoffset: 220; }
    100% { stroke-dashoffset: 0; }
  }

  /* Zones */
  .df-zones {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 16px;
    z-index: 2;
  }

  @media (max-width: 600px) {
    .df-zones {
      flex: none;
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  .df-room {
    background: #ffffff;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    border: 1px solid #e5e5ea;
    height: 80px;
  }

  @media (max-width: 600px) {
    .df-room {
      flex: 1 1 calc(50% - 16px);
      min-width: 140px;
    }
  }

  .df-room-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .df-room-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .df-room-source {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }
</style>
