<div class="infographic-step reverse-layout">
  <div class="step-content fade-in-up">
    <h3>Routes anywhere.</h3>
    <p>The Winada Audio Matrix intelligently routes different audio sources to different zones. Play ambient music in the lobby while someone else listens to a podcast in the kitchen.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    
    <div class="tree-container">
      <!-- The Matrix Hub -->
      <div class="tree-root hardware-panel">
        <div class="hub-label">Winada<br/>Audio Matrix</div>
        <div class="hub-ports">
          <div class="port"></div>
          <div class="port"></div>
          <div class="port"></div>
          <div class="port"></div>
        </div>
      </div>
      
      <!-- The Routing Branches -->
      <div class="tree-branches">
        
        <div class="room-branch">
          <div class="room-card hardware-panel">
            <div class="speaker-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
            </div>
            <div class="room-info">
              <span class="r-name">Lobby</span>
              <span class="r-source text-blue">Ambient</span>
            </div>
          </div>
        </div>

        <div class="room-branch">
          <div class="room-card hardware-panel">
            <div class="speaker-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
            </div>
            <div class="room-info">
              <span class="r-name">Office</span>
              <span class="r-source">Radio</span>
            </div>
          </div>
        </div>

        <div class="room-branch">
          <div class="room-card hardware-panel">
            <div class="speaker-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
            </div>
            <div class="room-info">
              <span class="r-name">Kitchen</span>
              <span class="r-source">Podcast</span>
            </div>
          </div>
        </div>

        <div class="room-branch">
          <div class="room-card hardware-panel">
            <div class="speaker-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg>
            </div>
            <div class="room-info">
              <span class="r-name">Patio</span>
              <span class="r-source text-blue">Spotify</span>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .reverse-layout {
    grid-template-columns: 1fr 1fr;
  }

  .reverse-layout .step-content {
    grid-column: 2;
    grid-row: 1;
  }
  
  .reverse-layout .step-visual {
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 900px) {
    .infographic-step, .reverse-layout {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
    .reverse-layout .step-content {
      grid-column: 1;
      grid-row: 1;
    }
    .reverse-layout .step-visual {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-visual {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* Tree Diagram Layout */
  .tree-container {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: 500px;
  }

  @media (max-width: 600px) {
    .tree-container {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* The Matrix Root */
  .tree-root {
    width: 140px;
    height: 140px;
    background: linear-gradient(145deg, #ffffff 0%, #f5f5f7 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    z-index: 2;
    flex-shrink: 0;
    border-radius: 24px;
  }

  @media (max-width: 600px) {
    .tree-root {
      width: 100%;
      height: 80px;
      flex-direction: row;
      justify-content: space-between;
      padding: 0 24px;
      border-radius: 16px;
    }
  }

  .hub-label {
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 1rem;
    text-align: center;
    line-height: 1.2;
  }

  .hub-ports {
    display: flex;
    gap: 8px;
  }

  .port {
    width: 8px;
    height: 8px;
    background: #1d1d1f;
    border-radius: 50%;
  }

  /* The Branches */
  .tree-branches {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-left: 40px;
    position: relative;
    flex: 1;
  }

  @media (max-width: 600px) {
    .tree-branches {
      padding-left: 20px;
      padding-top: 32px;
      width: 100%;
    }
  }

  /* Vertical Trunk Line */
  .tree-branches::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50px;
    bottom: 50px;
    width: 2px;
    background: var(--color-border);
    z-index: 1;
  }

  @media (max-width: 600px) {
    .tree-branches::before {
      left: 40px;
      top: -32px; /* Connect up to the Matrix */
      bottom: 40px;
    }
  }

  /* Horizontal Branch Lines */
  .room-branch {
    position: relative;
    display: flex;
    align-items: center;
  }

  .room-branch::before {
    content: '';
    position: absolute;
    left: -40px;
    top: 50%;
    width: 40px;
    height: 2px;
    background: var(--color-border);
    z-index: 1;
  }

  @media (max-width: 600px) {
    .room-branch::before {
      left: 20px; /* offset because of trunk at 40px */
      width: 20px; 
    }
    .room-branch {
      padding-left: 40px; /* push card to the right of trunk */
    }
  }

  .room-card {
    flex: 1;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    z-index: 2;
    background: #ffffff;
    border-radius: 16px;
  }

  .speaker-icon {
    color: var(--color-text-tertiary);
  }

  .room-info {
    display: flex;
    flex-direction: column;
  }

  .r-name {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .r-source {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .text-blue {
    color: var(--color-accent-blue);
    font-weight: 500;
  }
</style>
