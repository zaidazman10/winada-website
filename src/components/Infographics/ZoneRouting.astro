---
---

<div class="infographic-step reverse-layout">
  <div class="step-content fade-in-up">
    <h3>Different music in every room.</h3>
    <p>The central hub intelligently sends different audio to different areas of your building. Play relaxing music in the lobby while someone else listens to a podcast in the kitchen—all controlled from one smart box.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    
    <div class="blueprint-wrapper hardware-panel">
      <!-- SVG Wiring Layer -->
      <svg class="bp-wiring" viewBox="0 0 100 100" preserveAspectRatio="none">
        <!-- Top Left (Lobby) -->
        <path d="M 50 50 L 25 50 L 25 25" class="bp-wire" stroke="#34c759" opacity="0.3"/>
        <path d="M 50 50 L 25 50 L 25 25" class="bp-wire-pulse" stroke="#34c759"/>
        
        <!-- Top Right (Patio) -->
        <path d="M 50 50 L 75 50 L 75 25" class="bp-wire" stroke="#007aff" opacity="0.3"/>
        <path d="M 50 50 L 75 50 L 75 25" class="bp-wire-pulse" stroke="#007aff"/>
        
        <!-- Bottom Left (Office) -->
        <path d="M 50 50 L 25 50 L 25 75" class="bp-wire" stroke="#ff9500" opacity="0.3"/>
        <path d="M 50 50 L 25 50 L 25 75" class="bp-wire-pulse" stroke="#ff9500"/>
        
        <!-- Bottom Right (Kitchen) -->
        <path d="M 50 50 L 75 50 L 75 75" class="bp-wire" stroke="#af52de" opacity="0.3"/>
        <path d="M 50 50 L 75 50 L 75 75" class="bp-wire-pulse" stroke="#af52de"/>
      </svg>

      <!-- The Blueprint Grid -->
      <div class="blueprint-grid">
        <!-- Top Left -->
        <div class="bp-room">
          <div class="bp-room-header">
            <span class="bp-r-name">Lobby</span>
            <span class="bp-r-source" style="color: #34c759;">Ambient</span>
          </div>
          <div class="bp-r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></div>
        </div>

        <!-- Top Right -->
        <div class="bp-room">
          <div class="bp-room-header" style="align-items: flex-end; text-align: right;">
            <span class="bp-r-name">Patio</span>
            <span class="bp-r-source" style="color: #007aff;">Spotify</span>
          </div>
          <div class="bp-r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></div>
        </div>

        <!-- Bottom Left -->
        <div class="bp-room" style="justify-content: flex-end;">
          <div class="bp-r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></div>
          <div class="bp-room-header" style="margin-top: auto;">
            <span class="bp-r-name">Office</span>
            <span class="bp-r-source" style="color: #ff9500;">Radio</span>
          </div>
        </div>

        <!-- Bottom Right -->
        <div class="bp-room" style="justify-content: flex-end; align-items: flex-end;">
          <div class="bp-r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></div>
          <div class="bp-room-header" style="margin-top: auto; align-items: flex-end; text-align: right;">
            <span class="bp-r-name">Kitchen</span>
            <span class="bp-r-source" style="color: #af52de;">Podcast</span>
          </div>
        </div>
      </div>

      <!-- The Central Matrix Core -->
      <div class="bp-matrix">
        <span class="m-logo">CENTRAL HUB</span>
        <div class="m-ports">
          <div class="m-port" style="background: #34c759; box-shadow: 0 0 8px #34c759;"></div>
          <div class="m-port" style="background: #007aff; box-shadow: 0 0 8px #007aff;"></div>
          <div class="m-port" style="background: #ff9500; box-shadow: 0 0 8px #ff9500;"></div>
          <div class="m-port" style="background: #af52de; box-shadow: 0 0 8px #af52de;"></div>
        </div>
      </div>

    </div>

  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .reverse-layout {
    grid-template-columns: 1fr 1fr;
  }

  .reverse-layout .step-content {
    grid-column: 2;
    grid-row: 1;
  }
  
  .reverse-layout .step-visual {
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 900px) {
    .infographic-step, .reverse-layout {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
    .reverse-layout .step-content {
      grid-column: 1;
      grid-row: 1;
    }
    .reverse-layout .step-visual {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-visual {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* Architectural Blueprint Visual */
  .blueprint-wrapper {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1 / 1;
    background-color: #fbfbfd;
    background-image: 
      linear-gradient(rgba(0, 122, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 122, 255, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
    border-radius: 24px;
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  .bp-wiring {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
  }

  .bp-wire {
    fill: none;
    stroke-width: 0.5px;
  }

  .bp-wire-pulse {
    fill: none;
    stroke-width: 1px;
    stroke-linecap: round;
    stroke-dasharray: 10 50;
    animation: wirePulse 2.5s linear infinite;
  }

  @keyframes wirePulse {
    from { stroke-dashoffset: 60; }
    to { stroke-dashoffset: 0; }
  }

  .blueprint-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 2;
  }

  .bp-room {
    border: 1px solid rgba(0, 0, 0, 0.03);
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  @media (max-width: 500px) {
    .bp-room {
      padding: 16px;
    }
  }

  .bp-room-header {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .bp-r-name {
    font-size: clamp(0.875rem, 4vw, 1.125rem);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .bp-r-source {
    font-size: clamp(0.7rem, 3vw, 0.875rem);
    font-weight: 600;
  }

  .bp-r-icon {
    color: var(--color-text-tertiary);
    opacity: 0.5;
  }

  .bp-matrix {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140px;
    height: 140px;
    background: #1d1d1f;
    border-radius: 20px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    box-shadow: 0 16px 32px rgba(0,0,0,0.2), inset 0 1px 1px rgba(255,255,255,0.1);
  }

  @media (max-width: 500px) {
    .bp-matrix {
      width: 100px;
      height: 100px;
      gap: 8px;
      border-radius: 16px;
    }
  }
  @media (max-width: 380px) {
    .bp-matrix {
      width: 80px;
      height: 80px;
      gap: 4px;
      border-radius: 12px;
    }
  }

  .m-logo {
    color: #f5f5f7;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  @media (max-width: 500px) {
    .m-logo {
      font-size: 0.65rem;
    }
  }
  @media (max-width: 380px) {
    .m-logo {
      display: none;
    }
  }

  .m-ports {
    display: flex;
    gap: 12px;
  }

  @media (max-width: 500px) {
    .m-ports {
      gap: 8px;
    }
  }

  .m-port {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #333;
    border: 1px solid rgba(255,255,255,0.2);
  }

  @media (max-width: 500px) {
    .m-port {
      width: 8px;
      height: 8px;
    }
  }
</style>
