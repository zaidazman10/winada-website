---
---

<div class="infographic-step reverse-layout">
  <div class="step-content fade-in-up">
    <h3>Routes anywhere.</h3>
    <p>The Winada Controller intelligently routes different audio sources to different rooms. Play a podcast in the kitchen while someone else listens to Spotify in the living room.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    <div class="routing-diagram">
      <!-- The Hub -->
      <div class="hub-unit hardware-panel">
        <div class="hub-label">Winada Hub</div>
      </div>
      
      <!-- Lines -->
      <div class="routing-lines">
        <svg width="100%" height="100" preserveAspectRatio="none">
          <path d="M50%,0 C50%,50 20%,50 20%,100" stroke="#d2d2d7" stroke-width="2" fill="none"/>
          <path d="M50%,0 C50%,50 80%,50 80%,100" stroke="#d2d2d7" stroke-width="2" fill="none"/>
        </svg>
      </div>

      <!-- Rooms -->
      <div class="rooms-grid">
        <div class="room-card hardware-panel">
          <div class="speaker-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle><line x1="12" y1="6" x2="12.01" y2="6"></line></svg>
          </div>
          <div class="room-info">
            <span class="r-name">Living Room</span>
            <span class="r-source text-blue">Spotify</span>
          </div>
        </div>

        <div class="room-card hardware-panel">
          <div class="speaker-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle><line x1="12" y1="6" x2="12.01" y2="6"></line></svg>
          </div>
          <div class="room-info">
            <span class="r-name">Kitchen</span>
            <span class="r-source">Podcast</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .reverse-layout {
    grid-template-columns: 1fr 1fr;
  }

  .reverse-layout .step-content {
    grid-column: 2;
    grid-row: 1;
  }
  
  .reverse-layout .step-visual {
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 900px) {
    .infographic-step, .reverse-layout {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
    .reverse-layout .step-content {
      grid-column: 1;
      grid-row: 1;
    }
    .reverse-layout .step-visual {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-visual {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .routing-diagram {
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hub-unit {
    width: 200px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #f5f5f7 0%, #e8e8ed 100%);
    position: relative;
    z-index: 2;
  }

  .hub-label {
    font-weight: 600;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
  }

  .routing-lines {
    width: 100%;
    height: 100px;
    margin-top: -10px;
    margin-bottom: -10px;
    z-index: 1;
  }

  .rooms-grid {
    display: flex;
    justify-content: space-between;
    width: 100%;
    z-index: 2;
  }

  .room-card {
    width: 45%;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .speaker-icon {
    color: var(--color-text-tertiary);
  }

  .room-info {
    display: flex;
    flex-direction: column;
  }

  .r-name {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .r-source {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .text-blue {
    color: var(--color-accent-blue);
    font-weight: 500;
  }
</style>
