---

<div class="infographic-step reverse-layout">
  <div class="step-content fade-in-up">
    <h3>Routes anywhere.</h3>
    <p>The Winada Audio Matrix intelligently routes audio across multiple floors and zones. Play ambient music on the ground floor while streaming a podcast to the offices above—all from one highly-engineered central hub.</p>
  </div>
  
  <div class="step-visual fade-in-up">
    
    <div class="iso-wrapper">
      <div class="iso-scene">
        
        <!-- The Core: Audio Matrix -->
        <div class="iso-layer iso-base">
          <div class="base-surface">
            <span class="base-logo">WINADA CORE</span>
            <div class="base-ports">
              <div class="b-port"></div><div class="b-port"></div><div class="b-port"></div><div class="b-port active"></div>
            </div>
          </div>
        </div>

        <!-- Vertical Data Beams -->
        <div class="iso-beams">
          <div class="beam beam-1"></div>
          <div class="beam beam-2"></div>
        </div>

        <!-- Layer 1: Ground Floor -->
        <div class="iso-layer iso-floor iso-floor-1">
          <div class="floor-label">Ground Floor</div>
          
          <div class="iso-room">
            <div class="room-content">
              <span class="r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></span>
              <span class="r-name">Lobby</span>
              <span class="r-source text-blue">Ambient</span>
            </div>
          </div>

          <div class="iso-room">
            <div class="room-content">
              <span class="r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></span>
              <span class="r-name">Patio</span>
              <span class="r-source text-blue">Spotify</span>
            </div>
          </div>
        </div>

        <!-- Layer 2: First Floor -->
        <div class="iso-layer iso-floor iso-floor-2">
          <div class="floor-label">First Floor</div>

          <div class="iso-room">
            <div class="room-content">
              <span class="r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></span>
              <span class="r-name">Office</span>
              <span class="r-source">Radio</span>
            </div>
          </div>

          <div class="iso-room">
            <div class="room-content">
              <span class="r-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><circle cx="12" cy="14" r="4"></circle></svg></span>
              <span class="r-name">Kitchen</span>
              <span class="r-source">Podcast</span>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
  .infographic-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .reverse-layout {
    grid-template-columns: 1fr 1fr;
  }

  .reverse-layout .step-content {
    grid-column: 2;
    grid-row: 1;
  }
  
  .reverse-layout .step-visual {
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 900px) {
    .infographic-step, .reverse-layout {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 0;
    }
    .reverse-layout .step-content {
      grid-column: 1;
      grid-row: 1;
    }
    .reverse-layout .step-visual {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .step-content h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .step-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-visual {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* 3D Isometric Architecture Diagram */
  .iso-wrapper {
    perspective: 1200px;
    width: 100%;
    max-width: 500px;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    /* Scale down seamlessly on tiny screens */
    transform: scale(1);
  }

  @media (max-width: 500px) {
    .iso-wrapper {
      transform: scale(0.8);
      height: 400px;
    }
  }
  @media (max-width: 400px) {
    .iso-wrapper {
      transform: scale(0.65);
      height: 350px;
    }
  }

  .iso-scene {
    width: 280px;
    height: 280px;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(60deg) rotateZ(-45deg);
  }

  .iso-layer {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 16px;
    transform-style: preserve-3d;
  }

  /* The Matrix Hardware (Z=0) */
  .iso-base {
    background: #1d1d1f;
    transform: translateZ(0);
    box-shadow: 20px 20px 60px rgba(0,0,0,0.2);
  }
  /* 3D Box Sides */
  .iso-base::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 24px;
    background: #333336;
    bottom: -24px;
    left: 0;
    transform-origin: top;
    transform: rotateX(-90deg);
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
  }
  .iso-base::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 100%;
    background: #000000;
    top: 0;
    right: -24px;
    transform-origin: left;
    transform: rotateY(90deg);
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
  }

  .base-surface {
    position: absolute;
    inset: 12px;
    border: 1px solid #333;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 12px;
  }

  .base-logo {
    color: #86868b;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    transform: rotateZ(45deg) rotateX(-60deg);
    transform-origin: top left;
  }

  .base-ports {
    display: flex;
    gap: 8px;
    align-self: flex-end;
  }

  .b-port {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #333;
    border: 2px solid #555;
  }
  .b-port.active {
    background: #34c759;
    box-shadow: 0 0 8px #34c759;
  }

  /* The Glass Floors */
  .iso-floor {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.9);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  .iso-floor-1 {
    transform: translateZ(120px);
  }
  .iso-floor-2 {
    transform: translateZ(240px);
  }

  .floor-label {
    position: absolute;
    bottom: -32px;
    left: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    transform: rotateZ(45deg) rotateX(-60deg);
    transform-origin: bottom left;
  }

  /* Connecting Beams */
  .iso-beams {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }

  .beam {
    position: absolute;
    width: 4px;
    height: 240px; /* reaches floor 2 */
    background: var(--color-accent-blue);
    transform-origin: bottom;
    box-shadow: 0 0 12px var(--color-accent-blue);
  }

  .beam-1 {
    bottom: 50%;
    left: 40%;
    transform: rotateX(90deg); /* points straight up in 3D space */
  }
  .beam-2 {
    bottom: 30%;
    left: 70%;
    transform: rotateX(90deg);
    height: 120px; /* only reaches floor 1 */
  }

  /* Room Cards (Flat on the floors) */
  .iso-room {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 16px rgba(0,0,0,0.05);
    border: 1px solid #e5e5ea;
    position: relative;
    /* We keep the card flat, but un-rotate the text so it's readable */
  }

  .room-content {
    /* Un-rotate to face camera */
    transform: rotateZ(45deg) rotateX(-60deg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
    padding: 12px;
  }

  .r-icon {
    color: var(--color-text-tertiary);
    margin-bottom: 4px;
  }

  .r-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .r-source {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .text-blue {
    color: var(--color-accent-blue);
  }
</style>
