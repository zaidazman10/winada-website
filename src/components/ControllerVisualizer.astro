---
---

<section id="concept" class="visualizer-section section">
  <div class="container">
    <div class="section-header text-center fade-in-up">
      <h2>How The Controller Works</h2>
      <p>A central hub that takes your music sources and smartly routes them to any room.</p>
    </div>

    <div class="visualizer-container glass-panel fade-in-up">
      <!-- 1. Sources (Left) -->
      <div class="vis-column vis-sources">
        <h3 class="column-title">Music Sources</h3>
        <div class="vis-nodes">
          <div class="vis-node source-node">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
            <span>Spotify Connect</span>
          </div>
          <div class="vis-node source-node">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>
            <span>Local Server</span>
          </div>
          <div class="vis-node source-node">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
            <span>PA Override</span>
          </div>
        </div>
      </div>

      <!-- Connecting Lines (Left to Center) -->
      <div class="vis-connector">
        <svg viewBox="0 0 100 200" preserveAspectRatio="none" class="connector-svg">
          <path d="M0,33 C50,33 50,100 100,100" class="flow-line cyan-flow" />
          <path d="M0,100 L100,100" class="flow-line purple-flow" />
          <path d="M0,166 C50,166 50,100 100,100" class="flow-line cyan-flow" />
        </svg>
      </div>

      <!-- 2. The Controller Hub (Center) -->
      <div class="vis-column vis-hub">
        <div class="hub-core">
          <div class="hub-glow"></div>
          <svg class="hub-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M2 8h20"></path><path d="M6 12h.01"></path><path d="M10 12h.01"></path><path d="M14 12h.01"></path><path d="M18 12h.01"></path><path d="M6 16h.01"></path><path d="M10 16h.01"></path><path d="M14 16h.01"></path><path d="M18 16h.01"></path></svg>
          <div class="hub-label">Winada<br/>Controller</div>
        </div>
      </div>

      <!-- Connecting Lines (Center to Right) -->
      <div class="vis-connector">
        <svg viewBox="0 0 100 250" preserveAspectRatio="none" class="connector-svg">
          <path d="M0,125 C50,125 50,31 100,31" class="flow-line cyan-flow" />
          <path d="M0,125 C50,125 50,93 100,93" class="flow-line purple-flow" />
          <path d="M0,125 C50,125 50,156 100,156" class="flow-line cyan-flow" />
          <path d="M0,125 C50,125 50,218 100,218" class="flow-line cyan-flow" />
        </svg>
      </div>

      <!-- 3. Rooms (Right) -->
      <div class="vis-column vis-rooms">
        <h3 class="column-title">Your Rooms</h3>
        <div class="vis-nodes">
          <div class="vis-node room-node">
            <div class="room-info">
              <span class="room-name">Living Room</span>
              <span class="room-status cyan-text">Spotify • Vol 60%</span>
            </div>
            <div class="volume-bar"><div class="vol-fill cyan-bg" style="width: 60%"></div></div>
          </div>
          
          <div class="vis-node room-node">
            <div class="room-info">
              <span class="room-name">Kitchen</span>
              <span class="room-status purple-text">Local • Vol 30%</span>
            </div>
            <div class="volume-bar"><div class="vol-fill purple-bg" style="width: 30%"></div></div>
          </div>
          
          <div class="vis-node room-node">
            <div class="room-info">
              <span class="room-name">Patio</span>
              <span class="room-status cyan-text">Spotify • Vol 80%</span>
            </div>
            <div class="volume-bar"><div class="vol-fill cyan-bg" style="width: 80%"></div></div>
          </div>

          <div class="vis-node room-node">
            <div class="room-info">
              <span class="room-name">Bedroom</span>
              <span class="room-status muted-text">Off</span>
            </div>
            <div class="volume-bar"><div class="vol-fill" style="width: 0%"></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 48px;
  }
  
  .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 16px;
  }
  
  .section-header p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  .text-center {
    text-align: center;
  }

  /* Visualizer Grid Layout */
  .visualizer-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 60px 40px;
    gap: 16px;
    position: relative;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .visualizer-container {
      flex-direction: column;
      padding: 40px 20px;
      gap: 40px;
    }
  }

  .vis-column {
    display: flex;
    flex-direction: column;
    gap: 24px;
    flex: 1;
    z-index: 2;
  }

  .column-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    text-align: center;
    margin-bottom: 8px;
  }

  .vis-nodes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Nodes */
  .vis-node {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .source-node {
    justify-content: flex-start;
  }

  .source-node svg {
    color: var(--color-text-secondary);
  }

  .source-node span {
    font-weight: 500;
  }

  .room-node {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
  }

  .room-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .room-name {
    font-weight: 600;
  }

  .room-status {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Volume Bar */
  .volume-bar {
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
  }

  .vol-fill {
    height: 100%;
    border-radius: 2px;
  }

  /* Central Hub */
  .vis-hub {
    flex: 0 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hub-core {
    position: relative;
    width: 160px;
    height: 160px;
    background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.5), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }

  .hub-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(circle, var(--color-accent-cyan) 0%, transparent 70%);
    opacity: 0.15;
    z-index: -1;
    border-radius: 50%;
  }

  .hub-icon {
    color: var(--color-text-primary);
  }

  .hub-label {
    text-align: center;
    font-weight: 600;
    line-height: 1.2;
    font-size: 1.125rem;
  }

  /* Connectors (SVG Lines) */
  .vis-connector {
    flex: 0.5;
    height: 250px;
    display: flex;
    align-items: center;
  }

  .connector-svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .flow-line {
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .vis-connector {
      display: none; /* Hide SVG lines on mobile, stack gracefully */
    }
  }

  /* Utility Colors */
  .cyan-text { color: var(--color-accent-cyan); }
  .purple-text { color: var(--color-accent-purple); }
  .muted-text { color: var(--color-text-tertiary); }
  
  .cyan-bg { background: var(--color-accent-cyan); box-shadow: 0 0 10px rgba(0, 240, 255, 0.5); }
  .purple-bg { background: var(--color-accent-purple); box-shadow: 0 0 10px rgba(138, 43, 226, 0.5); }

  .cyan-flow { stroke: var(--color-accent-cyan); }
  .purple-flow { stroke: var(--color-accent-purple); }
</style>
