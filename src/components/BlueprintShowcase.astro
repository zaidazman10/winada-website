---
// BlueprintShowcase - Obsidian Spatial Audio Core Matrix
---

<section class="blueprint-section">
  <div class="container">
    
    <div class="section-header-block">
      <span class="meta-tag">[ SECTION 01 // AUDIO CONTROLLER ]</span>
      <h2 class="section-title">Play different music in every room.</h2>
      <p class="section-desc">
        Winada lets you control the music across different rooms from one simple web dashboard. Choose Spotify or local playlists, set volumes, and make announcements instantly.
      </p>
    </div>
    
    <div class="blueprint-columns">
      <!-- Left Column: Latency Inspector & Active Card -->
      <div class="blueprint-left-col">
        <!-- EQ & Core Monitor Panel -->
        <div class="inspector-box brand-card">
          <div class="inspector-header-top">
            <span class="inspector-title">[ LIVE ZONE STATUS ]</span>
            <!-- Bouncing EQ Audio Visualizer -->
            <div class="eq-visualizer">
              <div class="eq-bar bar-1"></div>
              <div class="eq-bar bar-2"></div>
              <div class="eq-bar bar-3"></div>
              <div class="eq-bar bar-4"></div>
              <div class="eq-bar bar-5"></div>
              <div class="eq-bar bar-6"></div>
              <div class="eq-bar bar-7"></div>
              <div class="eq-bar bar-8"></div>
            </div>
          </div>
          
          <div class="latency-table">
            <div class="table-header">
              <span>ROOM / ZONE</span>
              <span>RESPONSE</span>
              <span>STATUS</span>
            </div>
            
            <div class="table-row" data-row-link="dojo-main">
              <span class="zone-name">01 // DOJO MAIN</span>
              <span class="zone-delay">Instant</span>
              <span class="zone-status status-green">PLAYING</span>
            </div>
            
            <div class="table-row" data-row-link="momentum">
              <span class="zone-name">02 // MOMENTUM</span>
              <span class="zone-delay">Instant</span>
              <span class="zone-status status-cyan">PLAYING</span>
            </div>
            
            <div class="table-row" data-row-link="dojo-l3">
              <span class="zone-name">03 // DOJO @ L3</span>
              <span class="zone-delay">Instant</span>
              <span class="zone-status status-green">PLAYING</span>
            </div>
            
            <div class="table-row" data-row-link="outdoor">
              <span class="zone-name">04 // OUTDOOR TERRACE</span>
              <span class="zone-delay">Instant</span>
              <span class="zone-status status-cyan">PLAYING</span>
            </div>
          </div>
        </div>

        <!-- Detail Explanation Box -->
        <div class="detail-box brand-card">
          <div id="detail-default" class="detail-card active">
            <span class="detail-tag">[ SYSTEM STATE: ONLINE ]</span>
            <h4 class="detail-title">Centralized Music Control</h4>
            <p class="detail-desc">Manage your entire venue's audio from any phone, tablet, or web browser. Easily group rooms, adjust volume levels, and broadcast voice pages without any complicated hardware.</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Static Hardware Matrix SVG Blueprint -->
      <div class="blueprint-right-col">
        <div class="floor-plan-frame brand-card">
          <div class="blueprint-indicator">[ HARDWARE MATRIX SIGNAL FLOW ]</div>
          
          <div class="blueprint-canvas">
            <svg class="floor-plan-svg" viewBox="0 0 450 320" fill="none">
              <!-- SVG Definitions for Markers (Arrows) -->
              <defs>
                <marker id="arrow-cyan" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="5" markerHeight="5" orient="auto">
                  <path d="M 0 2 L 8 5 L 0 8 z" fill="var(--color-accent-cyan)" />
                </marker>
                <marker id="arrow-green" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="5" markerHeight="5" orient="auto">
                  <path d="M 0 2 L 8 5 L 0 8 z" fill="var(--color-accent-green)" />
                </marker>
                <marker id="arrow-gray" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="5" markerHeight="5" orient="auto">
                  <path d="M 0 2 L 8 5 L 0 8 z" fill="rgba(255, 255, 255, 0.15)" />
                </marker>
              </defs>

              <!-- Infographic Flow Step Titles -->
              <text x="60" y="22" text-anchor="middle" font-family="var(--font-mono)" font-size="8px" font-weight="700" fill="var(--color-text)" letter-spacing="1px">1. INPUT SOURCES</text>
              <text x="210" y="22" text-anchor="middle" font-family="var(--font-mono)" font-size="8px" font-weight="700" fill="var(--color-text)" letter-spacing="1px">2. CENTRAL CORE</text>
              <text x="360" y="22" text-anchor="middle" font-family="var(--font-mono)" font-size="8px" font-weight="700" fill="var(--color-text)" letter-spacing="1px">3. OUTPUT ROOMS</text>

              <!-- INPUT CAPSUELS (Left Side) -->
              <!-- Spotify Capsule -->
              <g class="input-node" id="in-spotify">
                <rect x="15" y="48" width="90" height="24" rx="4" fill="rgba(255, 255, 255, 0.02)" stroke="rgba(0, 240, 255, 0.2)" stroke-width="1" />
                <circle cx="30" cy="60" r="5" fill="var(--color-accent-cyan)" />
                <text x="43" y="63" font-family="var(--font-heading)" font-size="8px" font-weight="600" fill="var(--color-text)">Spotify Connect</text>
              </g>

              <!-- Local Media Capsule -->
              <g class="input-node" id="in-local">
                <rect x="15" y="138" width="90" height="24" rx="4" fill="rgba(255, 255, 255, 0.02)" stroke="rgba(57, 255, 20, 0.2)" stroke-width="1" />
                <circle cx="30" cy="150" r="5" fill="var(--color-accent-green)" />
                <text x="43" y="153" font-family="var(--font-heading)" font-size="8px" font-weight="600" fill="var(--color-text)">Local Library</text>
              </g>

              <!-- Page Override Capsule -->
              <g class="input-node" id="in-mic">
                <rect x="15" y="228" width="90" height="24" rx="4" fill="rgba(255, 255, 255, 0.02)" stroke="rgba(255, 0, 127, 0.2)" stroke-width="1" />
                <circle cx="30" cy="240" r="5" fill="var(--color-accent-pink)" />
                <text x="43" y="243" font-family="var(--font-heading)" font-size="8px" font-weight="600" fill="var(--color-text)">Voice Page</text>
              </g>

              <!-- Central Controller Core (Rack Chassis style) -->
              <g class="controller-chassis" id="core-chassis">
                <rect x="165" y="42" width="90" height="220" rx="6" fill="rgba(9, 10, 15, 0.6)" stroke="rgba(255, 255, 255, 0.12)" stroke-width="1.5" />
                <rect x="173" y="52" width="74" height="200" rx="4" fill="rgba(0, 0, 0, 0.4)" stroke="rgba(255, 255, 255, 0.05)" />
                
                <!-- Internal Grid Lines for Matrix paths -->
                <line x1="185" y1="52" x2="185" y2="252" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1" />
                <line x1="210" y1="52" x2="210" y2="252" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1" />
                <line x1="235" y1="52" x2="235" y2="252" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1" />
                
                <!-- Central processor label -->
                <text x="210" y="63" text-anchor="middle" font-family="var(--font-mono)" font-size="5.5px" fill="rgba(255, 255, 255, 0.3)" letter-spacing="0.5px">WINADA CORE</text>
                
                <!-- Matrix Junction Crosspoints (LED indicator circles) -->
                <!-- Spotify to Zone 2 & 4 -->
                <circle cx="185" cy="122" r="3" fill="var(--color-accent-cyan)" class="matrix-led led-spotify static-active" />
                <circle cx="185" cy="242" r="3" fill="var(--color-accent-cyan)" class="matrix-led led-spotify static-active" />
                <!-- Local Media to Zone 1 & 3 -->
                <circle cx="210" cy="72" r="3" fill="var(--color-accent-green)" class="matrix-led led-local static-active" />
                <circle cx="210" cy="182" r="3" fill="var(--color-accent-green)" class="matrix-led led-local static-active" />
                <!-- Mic Paging overrides (standby / normally off) -->
                <circle cx="235" cy="72" r="3.5" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 0, 127, 0.2)" stroke-width="0.7" />
                <circle cx="235" cy="122" r="3.5" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 0, 127, 0.2)" stroke-width="0.7" />
                <circle cx="235" cy="182" r="3.5" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 0, 127, 0.2)" stroke-width="0.7" />
                <circle cx="235" cy="242" r="3.5" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 0, 127, 0.2)" stroke-width="0.7" />
              </g>

              <!-- Central Routing Paths (Inputs to Core Chassis) with directional arrows -->
              <path d="M 105 60 L 160 60" stroke="var(--color-accent-cyan)" stroke-width="1.5" marker-end="url(#arrow-cyan)" class="routing-line static-active-cyan" />
              <path d="M 105 150 L 160 150" stroke="var(--color-accent-green)" stroke-width="1.5" marker-end="url(#arrow-green)" class="routing-line static-active-green" />
              <path d="M 105 240 L 160 240" stroke="rgba(255, 255, 255, 0.15)" stroke-width="1.5" marker-end="url(#arrow-gray)" class="routing-line" />

              <!-- Output Zone Channels (Right Side) -->
              
              <!-- Zone 1: Dojo Main -->
              <g class="room-zone" data-room="dojo-main">
                <rect x="295" y="48" width="135" height="48" rx="6" fill="transparent" class="room-rect" />
                <text x="305" y="62" class="room-label">01 // DOJO MAIN</text>
                
                <!-- Zone volume dial widget -->
                <circle cx="398" cy="72" r="7" fill="rgba(57, 255, 20, 0.08)" stroke="var(--color-accent-green)" stroke-width="1" class="speaker-node" />
                <line x1="398" y1="72" x2="398" y2="66" stroke="var(--color-accent-green)" stroke-width="1.2" stroke-linecap="round" />
                
                <text x="305" y="82" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">VOL: 75% | SRC: LOCAL</text>
                
                <!-- Signal connection line from Core to Zone -->
                <path d="M 255 72 L 290 72" stroke="var(--color-accent-green)" stroke-width="1.2" marker-end="url(#arrow-green)" class="signal-line static-active-green" />
              </g>

              <!-- Zone 2: Momentum -->
              <g class="room-zone" data-room="momentum">
                <rect x="295" y="108" width="135" height="48" rx="6" fill="transparent" class="room-rect" />
                <text x="305" y="122" class="room-label">02 // MOMENTUM</text>
                
                <!-- Zone volume dial widget -->
                <circle cx="398" cy="132" r="7" fill="rgba(0, 240, 255, 0.08)" stroke="var(--color-accent-cyan)" stroke-width="1" class="speaker-node" />
                <line x1="398" y1="132" x2="402" y2="127" stroke="var(--color-accent-cyan)" stroke-width="1.2" stroke-linecap="round" />
                
                <text x="305" y="142" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">VOL: 16% | SRC: SPOTIFY</text>
                
                <!-- Signal connection line from Core to Zone -->
                <path d="M 255 122 L 290 122" stroke="var(--color-accent-cyan)" stroke-width="1.2" marker-end="url(#arrow-cyan)" class="signal-line static-active-cyan" />
              </g>

              <!-- Zone 3: Dojo @ L3 -->
              <g class="room-zone" data-room="dojo-l3">
                <rect x="295" y="168" width="135" height="48" rx="6" fill="transparent" class="room-rect" />
                <text x="305" y="182" class="room-label">03 // DOJO @ L3</text>
                
                <!-- Zone volume dial widget -->
                <circle cx="398" cy="192" r="7" fill="rgba(57, 255, 20, 0.08)" stroke="var(--color-accent-green)" stroke-width="1" class="speaker-node" />
                <line x1="398" y1="192" x2="394" y2="187" stroke="var(--color-accent-green)" stroke-width="1.2" stroke-linecap="round" />
                
                <text x="305" y="202" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">VOL: 100% | SRC: LOCAL</text>
                
                <!-- Signal connection line from Core to Zone -->
                <path d="M 255 182 L 290 182" stroke="var(--color-accent-green)" stroke-width="1.2" marker-end="url(#arrow-green)" class="signal-line static-active-green" />
              </g>

              <!-- Zone 4: Outdoor -->
              <g class="room-zone" data-room="outdoor">
                <rect x="295" y="228" width="135" height="48" rx="6" fill="transparent" class="room-rect" />
                <text x="305" y="242" class="room-label">04 // OUTDOOR</text>
                
                <!-- Zone volume dial widget -->
                <circle cx="398" cy="252" r="7" fill="rgba(0, 240, 255, 0.08)" stroke="var(--color-accent-cyan)" stroke-width="1" class="speaker-node" />
                <line x1="398" y1="252" x2="394" y2="247" stroke="var(--color-accent-cyan)" stroke-width="1.2" stroke-linecap="round" />
                
                <text x="305" y="262" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">VOL: 45% | SRC: SPOTIFY</text>
                
                <!-- Signal connection line from Core to Zone -->
                <path d="M 255 242 L 290 242" stroke="var(--color-accent-cyan)" stroke-width="1.2" marker-end="url(#arrow-cyan)" class="signal-line static-active-cyan" />
              </g>

              <!-- Color-Coded Signal Flow Legend at bottom -->
              <g class="diagram-legend">
                <!-- Spotify legend item -->
                <circle cx="70" cy="295" r="4.5" fill="var(--color-accent-cyan)" />
                <text x="80" y="298" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">Spotify Route</text>

                <!-- Local Media legend item -->
                <circle cx="180" cy="295" r="4.5" fill="var(--color-accent-green)" />
                <text x="190" y="298" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">Local Library Route</text>

                <!-- Standby paging legend item -->
                <circle cx="295" cy="295" r="4.5" fill="rgba(255, 255, 255, 0.15)" stroke="var(--color-accent-pink)" stroke-width="1" />
                <text x="305" y="298" font-family="var(--font-mono)" font-size="7px" fill="var(--color-text-muted)">Paging Override (Standby)</text>
              </g>
              
            </svg>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .blueprint-section {
    position: relative;
    padding-top: 120px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 600px) {
    .blueprint-section {
      padding-top: 90px;
    }
  }

  .section-header-block {
    margin-bottom: 40px;
  }

  .blueprint-columns {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 36px;
    align-items: start;
  }

  .blueprint-left-col {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* Monospace Inspector Table */
  .inspector-box {
    padding: 24px;
    background: rgba(255, 255, 255, 0.01);
  }

  .inspector-header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .inspector-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 1.5px;
    font-weight: 600;
  }

  /* EQ Visualizer */
  .eq-visualizer {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 16px;
  }

  .eq-bar {
    width: 2px;
    background: linear-gradient(to top, var(--color-accent-cyan), var(--color-accent-pink));
    animation: bounce 0.8s ease-in-out infinite alternate;
  }

  .bar-1 { animation-delay: -0.1s; height: 30%; }
  .bar-2 { animation-delay: -0.5s; height: 60%; }
  .bar-3 { animation-delay: -0.3s; height: 90%; }
  .bar-4 { animation-delay: -0.7s; height: 40%; }
  .bar-5 { animation-delay: -0.2s; height: 75%; }
  .bar-6 { animation-delay: -0.6s; height: 20%; }
  .bar-7 { animation-delay: -0.4s; height: 85%; }
  .bar-8 { animation-delay: -0.8s; height: 50%; }

  @keyframes bounce {
    0% { height: 15%; }
    100% { height: 95%; }
  }

  .latency-table {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .table-header {
    display: grid;
    grid-template-columns: 2.2fr 1fr 1fr;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 8px;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }

  .table-row {
    display: grid;
    grid-template-columns: 2.2fr 1fr 1fr;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    cursor: default;
    background: rgba(255, 255, 255, 0.01);
    border-radius: 8px;
    transition: all var(--transition-smooth);
  }

  .zone-name {
    color: var(--color-text);
  }

  .zone-delay {
    color: var(--color-text-muted);
  }

  .zone-status {
    font-weight: 700;
    text-anchor: end;
    text-align: right;
    font-size: 0.7rem;
    letter-spacing: 0.5px;
  }

  .status-cyan { color: var(--color-accent-cyan); }
  .status-pink { color: var(--color-accent-pink); }
  .status-green { color: var(--color-accent-green); }

  /* Feature Explanation Box */
  .detail-box {
    padding: 28px;
    min-height: 140px;
  }

  .detail-card {
    display: none;
    flex-direction: column;
    gap: 8px;
  }

  .detail-card.active {
    display: flex;
    animation: fade-in 0.25s ease-out;
  }

  .detail-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  .detail-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .detail-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Right column: Blueprint schematic frame */
  .blueprint-right-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .floor-plan-frame {
    width: 100%;
    padding: 40px 24px 24px;
    position: relative;
    background: rgba(255, 255, 255, 0.01);
  }

  .blueprint-indicator {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    position: absolute;
    top: 14px;
    left: 24px;
    letter-spacing: 1px;
  }

  .blueprint-canvas {
    width: 100%;
    overflow: visible;
  }

  .floor-plan-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* INPUT NODES */
  .input-node {
    cursor: default;
  }

  .input-icon {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 10px;
    fill: var(--color-text-muted);
  }

  .input-label {
    font-family: var(--font-mono);
    font-size: 7px;
    fill: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* ROUTING LINES */
  .routing-line {
    opacity: 0.15;
    stroke: rgba(255, 255, 255, 0.12);
  }

  .routing-line.static-active-cyan {
    stroke: var(--color-accent-cyan);
    opacity: 0.85;
    stroke-width: 1.8px;
    stroke-dasharray: 6 4;
    animation: flow 1.8s linear infinite;
  }

  .routing-line.static-active-green {
    stroke: var(--color-accent-green);
    opacity: 0.85;
    stroke-width: 1.8px;
    stroke-dasharray: 6 4;
    animation: flow 1.8s linear infinite;
  }

  @keyframes flow {
    to { stroke-dashoffset: -20; }
  }

  /* HARDWARE MATRIX & CHASSIS */
  .controller-chassis {
    transition: all var(--transition-smooth);
  }

  .matrix-led {
    opacity: 0.2;
  }

  .matrix-led.static-active {
    opacity: 1;
    r: 3.5px;
  }

  .matrix-led.led-spotify.static-active {
    fill: var(--color-accent-cyan);
    filter: drop-shadow(0 0 4px var(--color-accent-cyan));
  }

  .matrix-led.led-local.static-active {
    fill: var(--color-accent-green);
    filter: drop-shadow(0 0 4px var(--color-accent-green));
  }

  /* ZONE OUTPUT PANELS */
  .room-rect {
    stroke: rgba(255, 255, 255, 0.08);
    fill: rgba(255, 255, 255, 0.01);
  }

  .room-label {
    font-family: var(--font-mono);
    font-size: 7.5px;
    font-weight: 600;
    fill: var(--color-text-muted);
    letter-spacing: 0.5px;
    pointer-events: none;
  }

  .speaker-node {
    transition: all var(--transition-smooth);
  }

  .signal-line {
    opacity: 0.15;
    stroke: rgba(255, 255, 255, 0.12);
  }

  .signal-line.static-active-cyan {
    stroke: var(--color-accent-cyan);
    opacity: 0.85;
    stroke-dasharray: 5 3;
    animation: flow 1.8s linear infinite;
  }

  .signal-line.static-active-green {
    stroke: var(--color-accent-green);
    opacity: 0.85;
    stroke-dasharray: 5 3;
    animation: flow 1.8s linear infinite;
  }
  
  /* Output Zone Groups (Clean static borders) */
  .room-zone {
    cursor: default;
  }

  .room-zone[data-room="dojo-main"] .room-rect,
  .room-zone[data-room="dojo-l3"] .room-rect {
    stroke: rgba(57, 255, 20, 0.15);
  }
  .room-zone[data-room="dojo-main"] .room-label,
  .room-zone[data-room="dojo-l3"] .room-label {
    fill: rgba(57, 255, 20, 0.85);
  }

  .room-zone[data-room="momentum"] .room-rect,
  .room-zone[data-room="outdoor"] .room-rect {
    stroke: rgba(0, 240, 255, 0.15);
  }
  .room-zone[data-room="momentum"] .room-label,
  .room-zone[data-room="outdoor"] .room-label {
    fill: rgba(0, 240, 255, 0.85);
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .blueprint-columns {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 600px) {
    .floor-plan-frame {
      padding: 28px 16px 16px;
    }
    .room-label {
      font-size: 7px;
