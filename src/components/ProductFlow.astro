---
// ProductFlow - Minimalist vector representation of infinite/scalable multi-zone audio routing fanning out of the W Logo
---

<section class="section" id="product-flow">
  <div class="container">
    <span class="meta-tag">[ ROUTING MODEL: DYNAMIC MATRIX ]</span>
    <h2 class="section-title">Multi-Room Routing.</h2>
    <p class="section-desc">
      One music source splits easily into multiple rooms. You can control which areas play music while everything stays perfectly synchronized with zero lag.
    </p>

    <!-- Glass card container for the flow chart -->
    <div class="brand-card flow-deck-card">
      <div class="matrix-spec-tag">[ SIGNAL DISTRIBUTION CORE ]</div>

      <svg class="flow-svg" viewBox="0 0 900 360" fill="none">
        <!-- Definitions for gradients -->
        <defs>
          <linearGradient id="gradient-z1" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-text)" stop-opacity="0.15" />
            <stop offset="40%" stop-color="var(--color-zone-1)" />
            <stop offset="100%" stop-color="var(--color-zone-1)" />
          </linearGradient>
          <linearGradient id="gradient-z2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-text)" stop-opacity="0.15" />
            <stop offset="40%" stop-color="var(--color-zone-2)" />
            <stop offset="100%" stop-color="var(--color-zone-2)" />
          </linearGradient>
          <linearGradient id="gradient-z3" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-text)" stop-opacity="0.15" />
            <stop offset="40%" stop-color="var(--color-zone-3)" />
            <stop offset="100%" stop-color="var(--color-zone-3)" />
          </linearGradient>
          <linearGradient id="gradient-z4" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-text)" stop-opacity="0.15" />
            <stop offset="40%" stop-color="var(--color-zone-4)" />
            <stop offset="100%" stop-color="var(--color-zone-4)" />
          </linearGradient>
          <linearGradient id="gradient-z5" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-text)" stop-opacity="0.15" />
            <stop offset="40%" stop-color="var(--color-zone-5)" />
            <stop offset="100%" stop-color="var(--color-zone-5)" />
          </linearGradient>
          <linearGradient id="gradient-zn" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-text)" stop-opacity="0.1" />
            <stop offset="40%" stop-color="var(--color-text-darker)" />
            <stop offset="100%" stop-color="var(--color-text-darker)" />
          </linearGradient>
        </defs>

        <!-- Grid backings -->
        <line x1="50" y1="30" x2="850" y2="30" stroke="rgba(18,18,20,0.01)" />
        <line x1="50" y1="90" x2="850" y2="90" stroke="rgba(18,18,20,0.01)" />
        <line x1="50" y1="150" x2="850" y2="150" stroke="rgba(18,18,20,0.01)" />
        <line x1="50" y1="210" x2="850" y2="210" stroke="rgba(18,18,20,0.01)" />
        <line x1="50" y1="270" x2="850" y2="270" stroke="rgba(18,18,20,0.01)" />
        <line x1="50" y1="330" x2="850" y2="330" stroke="rgba(18,18,20,0.01)" />

        <!-- Input Audio stream wave entering Left of W -->
        <path 
          d="M 50 180 Q 100 130 150 180 T 235 180" 
          stroke="var(--color-text)" 
          stroke-width="2" 
          class="pulse-path"
        />

        <!-- Fiber paths branching out of the right side of the W logo (at x=265) -->
        <path d="M 265 180 C 350 180, 450 30, 550 30 L 850 30" stroke="url(#gradient-z1)" stroke-width="1.5" />
        <path d="M 265 180 C 350 180, 450 90, 550 90 L 850 90" stroke="url(#gradient-z2)" stroke-width="1.5" />
        <path d="M 265 180 C 350 180, 450 150, 550 150 L 850 150" stroke="url(#gradient-z3)" stroke-width="1.5" />
        <path d="M 265 180 C 350 180, 450 210, 550 210 L 850 210" stroke="url(#gradient-z4)" stroke-width="1.5" />
        <path d="M 265 180 C 350 180, 450 270, 550 270 L 850 270" stroke="url(#gradient-z5)" stroke-width="1.5" />
        <path d="M 265 180 C 350 180, 450 330, 550 330 L 850 330" stroke="url(#gradient-zn)" stroke-width="1.2" stroke-dasharray="3 3" opacity="0.3" />

        <!-- Sound node pulses traveling along the paths -->
        <circle r="4" fill="var(--color-zone-1)">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M 265 180 C 350 180, 450 30, 550 30 L 850 30" />
        </circle>
        <circle r="4" fill="var(--color-zone-2)">
          <animateMotion dur="2.8s" begin="0.4s" repeatCount="indefinite" path="M 265 180 C 350 180, 450 90, 550 90 L 850 90" />
        </circle>
        <circle r="4" fill="var(--color-zone-3)">
          <animateMotion dur="2.2s" begin="0.8s" repeatCount="indefinite" path="M 265 180 C 350 180, 450 150, 550 150 L 850 150" />
        </circle>
        <circle r="4" fill="var(--color-zone-4)">
          <animateMotion dur="2.6s" begin="1.2s" repeatCount="indefinite" path="M 265 180 C 350 180, 450 210, 550 210 L 850 210" />
        </circle>
        <circle r="4" fill="var(--color-zone-5)">
          <animateMotion dur="3s" begin="1.6s" repeatCount="indefinite" path="M 265 180 C 350 180, 450 270, 550 270 L 850 270" />
        </circle>

        <!-- Dynamic Brand routing hub node (W Wave Logo shape) -->
        <g transform="translate(230, 160)">
          <!-- Background shield behind logo -->
          <circle cx="20" cy="20" r="18" fill="var(--color-bg)" stroke="var(--color-border-strong)" stroke-width="1" />
          <path 
            d="M 8 13 L 16 27 L 20 20 L 24 27 L 32 13" 
            stroke="var(--color-brand)" 
            stroke-width="2.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          />
        </g>
      </svg>

      <!-- Minimal overlay labels -->
      <div class="labels-container">
        <div class="label-item source-label">
          <span class="label-dot"></span>
          <div>
            <h5>MUSIC INPUT</h5>
            <p>Spotify, files, or radio</p>
          </div>
        </div>

        <div class="label-item split-label">
          <span class="label-dot blink"></span>
          <div>
            <h5>WINADA ENGINE</h5>
            <p>Routes sound to any room</p>
          </div>
        </div>

        <div class="label-group sinks-labels">
          <div class="label-item sink-label">
            <span class="label-dot bg-orange"></span>
            <div><h5>ZONE 01</h5></div>
          </div>
          <div class="label-item sink-label">
            <span class="label-dot bg-teal"></span>
            <div><h5>ZONE 02</h5></div>
          </div>
          <div class="label-item sink-label">
            <span class="label-dot bg-violet"></span>
            <div><h5>ZONE 03</h5></div>
          </div>
          <div class="label-item sink-label">
            <span class="label-dot bg-amber"></span>
            <div><h5>ZONE 04</h5></div>
          </div>
          <div class="label-item sink-label">
            <span class="label-dot bg-rose"></span>
            <div><h5>ZONE 05</h5></div>
          </div>
          <div class="label-item sink-label fader">
            <span class="label-dot bg-dark"></span>
            <div><h5>ZONE ... [N]</h5></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .flow-deck-card {
    margin-top: 48px;
    padding: 48px;
    position: relative;
  }

  .matrix-spec-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-darker);
    position: absolute;
    top: 18px;
    left: 20px;
  }

  .flow-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .labels-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    padding: 48px;
  }

  .label-item {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .label-item h5 {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--color-text);
  }

  .label-item p {
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(18, 18, 20, 0.2);
  }

  .label-dot.blink {
    background: var(--color-brand);
    box-shadow: 0 0 6px var(--color-brand);
    animation: blink 2s infinite;
  }

  .bg-orange { background: var(--color-zone-1); box-shadow: 0 0 8px var(--color-zone-1); }
  .bg-teal { background: var(--color-zone-2); box-shadow: 0 0 8px var(--color-zone-2); }
  .bg-violet { background: var(--color-zone-3); box-shadow: 0 0 8px var(--color-zone-3); }
  .bg-amber { background: var(--color-zone-4); box-shadow: 0 0 8px var(--color-zone-4); }
  .bg-rose { background: var(--color-zone-5); box-shadow: 0 0 8px var(--color-zone-5); }
  .bg-dark { background: var(--color-text-darker); }

  .source-label {
    left: 5%;
    top: 51%;
  }

  .split-label {
    left: 28%;
    top: 51%;
  }

  .sinks-labels {
    position: absolute;
    right: 5%;
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    height: 100%;
    padding: 20px 0;
  }

  .sink-label {
    position: relative;
  }

  .sink-label.fader {
    opacity: 0.5;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  @media (max-width: 768px) {
    .flow-deck-card {
      padding: 24px 16px;
    }

    .labels-container {
      position: relative;
      inset: auto;
      padding: 24px 0 0 0;
      display: flex;
      flex-direction: column;
      gap: 20px;
      pointer-events: auto;
    }

    .source-label,
    .split-label {
      position: relative;
      left: auto;
      top: auto;
    }

    .sinks-labels {
      position: relative;
      right: auto;
      top: auto;
      bottom: auto;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      height: auto;
      padding: 16px 0 0 0;
      border-top: 1px dashed var(--color-border-strong);
    }

    .sink-label {
      position: relative;
    }
  }
</style>
