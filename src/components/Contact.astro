---
---

<section id="contact" class="contact-section section">
  <div class="container">
    <div class="contact-card hardware-panel fade-in-up">
      <div class="contact-content">
        <h2>Design your audio solution.</h2>
        <p>Partner with us for a complete, end-to-end audio architecture tailored specifically for your space—from homes to commercial venues.</p>
      </div>
      
      <form class="contact-form" action="#" method="POST" onsubmit="event.preventDefault();">
        <div class="form-group">
          <input type="text" id="name" name="name" placeholder="Name" required />
        </div>
        
        <div class="form-group">
          <input type="email" id="email" name="email" placeholder="Email" required />
        </div>

        <div class="form-group">
          <select id="project-type" name="project-type">
            <option value="" disabled selected>Project Type</option>
            <option value="residential">Residential (Home)</option>
            <option value="commercial">Commercial (Office, Retail, Hospitality)</option>
          </select>
        </div>
        
        <button type="submit" class="btn-primary form-submit">Request Consultation</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-bottom: 120px;
  }

  .contact-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    padding: 60px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .contact-card {
      grid-template-columns: 1fr;
      padding: 40px 24px;
      gap: 40px;
    }
  }

  .contact-content h2 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .contact-content p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  input, select {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-text-primary);
    padding: 16px;
    font-family: var(--font-primary);
    font-size: 17px;
    border-radius: 12px;
    outline: none;
    transition: all var(--transition-snappy);
    width: 100%;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  input::placeholder {
    color: var(--color-text-tertiary);
  }

  input:focus, select:focus {
    border-color: var(--color-accent-blue);
    background: rgba(0, 0, 0, 0.6);
    box-shadow: 0 0 0 3px rgba(0, 242, 254, 0.2);
  }

  select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23a1a1a6' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 16px center;
    background-size: 16px;
    color: var(--color-text-tertiary);
  }
  
  select:not(:invalid) {
    color: var(--color-text-primary);
  }

  .form-submit {
    margin-top: 8px;
    width: 100%;
    cursor: pointer;
    padding: 16px;
    font-weight: 600;
  }
</style>
