---
const technicalSpecs = [
  { 
    category: "SYSTEM PERFORMANCE", 
    accent: "cyan",
    items: [
      { label: "Volume response", value: "Instant volume changes (under 0.1 seconds)" },
      { label: "Control options", value: "Control from your Phone, Tablet, or Wall Keypads" },
      { label: "Room capacity", value: "Up to 32 independent music zones per building" },
      { label: "Source switching", value: "Switch music players instantly without lag" }
    ]
  },
  { 
    category: "CONNECTIONS & SOURCES", 
    accent: "pink",
    items: [
      { label: "Supported music", value: "Spotify Connect, Local Audio Library, Web Radio" },
      { label: "Analog input", value: "Direct AUX input jack for external players" },
      { label: "Wall controllers", value: "Optional physical knobs for manual room volume" },
      { label: "Announcements", value: "Auto-fades music volume during voice paging" }
    ]
  },
  { 
    category: "SOFTWARE & SECURITY", 
    accent: "green",
    items: [
      { label: "Smart integration", value: "Open API for smart home & building automation" },
      { label: "Web dashboard", value: "Clean, responsive browser app for all devices" },
      { label: "PIN Lock security", value: "Optional screen lock to prevent customer tampering" },
      { label: "Self-healing core", value: "Watchdog service auto-restarts music players if they crash" }
    ]
  }
];
---

<section class="section" id="datasheet">
  <div class="container specs-container">
    <span class="meta-tag">[ SPECIFICATIONS // SYSTEM DATASHEET ]</span>
    <h2 class="section-title">Technical specifications.</h2>
    
    <div class="datasheet-grid">
      {technicalSpecs.map((cat) => (
        <div class={`datasheet-plate brand-card accent-${cat.accent}`}>
          <div class="datasheet-header">{cat.category}</div>
          <ul class="spec-list">
            {cat.items.map((item) => (
              <li class="spec-item">
                <span class="spec-label">{item.label}</span>
                <span class="spec-value">{item.value}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .specs-container {
    padding-top: 24px;
  }

  .datasheet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 36px;
  }

  .datasheet-plate {
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
  }

  .datasheet-header {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }

  /* Color Theme Accents */
  .accent-cyan .datasheet-header {
    color: var(--color-accent-cyan);
    border-color: rgba(0, 240, 255, 0.15);
  }
  .accent-cyan:hover {
    border-color: rgba(0, 240, 255, 0.3);
    box-shadow: 0 12px 40px rgba(0, 240, 255, 0.05);
  }

  .accent-pink .datasheet-header {
    color: var(--color-accent-pink);
    border-color: rgba(255, 0, 127, 0.15);
  }
  .accent-pink:hover {
    border-color: rgba(255, 0, 127, 0.3);
    box-shadow: 0 12px 40px rgba(255, 0, 127, 0.05);
  }

  .accent-green .datasheet-header {
    color: var(--color-accent-green);
    border-color: rgba(57, 255, 20, 0.15);
  }
  .accent-green:hover {
    border-color: rgba(57, 255, 20, 0.3);
    box-shadow: 0 12px 40px rgba(57, 255, 20, 0.05);
  }

  .spec-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    list-style: none;
  }

  .spec-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .spec-label {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 0.7rem;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Glowing dot next to label */
  .spec-label::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .accent-cyan .spec-label::before { background: var(--color-accent-cyan); box-shadow: 0 0 6px var(--color-accent-cyan); }
  .accent-pink .spec-label::before { background: var(--color-accent-pink); box-shadow: 0 0 6px var(--color-accent-pink); }
  .accent-green .spec-label::before { background: var(--color-accent-green); box-shadow: 0 0 6px var(--color-accent-green); }

  .spec-value {
    font-family: var(--font-body);
    color: var(--color-text);
    font-size: 0.88rem;
    line-height: 1.4;
    font-weight: 400;
  }

  @media (max-width: 900px) {
    .datasheet-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 600px) {
    .datasheet-plate {
      padding: 24px;
    }
    .spec-list {
      gap: 16px;
    }
    .spec-value {
      font-size: 0.85rem;
    }
  }
</style>