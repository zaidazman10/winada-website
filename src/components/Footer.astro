---
// Stripped down minimal footer aligned to brand layout
---

<footer class="footer">
  <div class="container">
    <div class="brand-card footer-deck">
      <div class="footer-left">
        <!-- Folded W wave logo mark -->
        <svg class="logo-mark" viewBox="0 0 40 40" fill="none">
          <path 
            d="M 6 10 L 14 30 L 20 18 L 26 30 L 34 10" 
            stroke="var(--color-brand)" 
            stroke-width="3" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          />
        </svg>
        <span class="brand-sub">winada <span class="sub-product">multizone audio</span></span>
      </div>
      <div class="footer-right">
        &copy; {new Date().getFullYear()} Winada. Built for Linux hardware.
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 80px 0 60px;
    background: transparent;
  }

  .footer-deck {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 24px 32px;
  }

  .logo-mark {
    width: 20px;
    height: 20px;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-sub {
    font-weight: 600;
    color: var(--color-text);
  }

  .sub-product {
    font-weight: 300;
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    .footer-deck {
      flex-direction: column;
      gap: 16px;
      text-align: center;
      padding: 24px;
    }
  }
</style>
