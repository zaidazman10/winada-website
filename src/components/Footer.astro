---
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-name">WINADA</span>
      <span class="brand-tagline">Premium Audio Controller</span>
    </div>
    
    <div class="footer-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="#">Support</a>
    </div>
    
    <div class="footer-copyright">
      &copy; {new Date().getFullYear()} Winada. All rights reserved.
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-base);
    padding: 60px 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .brand-name {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
  }

  .brand-tagline {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition-snappy);
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }

  .footer-copyright {
    margin-top: 16px;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }
</style>
