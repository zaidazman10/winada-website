---
// Footer - Obsidian style minimal footer
---

<footer class="footer">
  <div class="container">
    <div class="footer-console-plate">
      <div class="footer-left">
        <!-- Fluid bezier soundwave gradient logo mark -->
        <svg class="logo-mark" viewBox="0 0 40 40" fill="none">
          <defs>
            <linearGradient id="footer-logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="var(--color-accent-cyan)" />
              <stop offset="100%" stop-color="var(--color-accent-pink)" />
            </linearGradient>
          </defs>
          <path 
            d="M 6 18 C 10 5, 14 35, 18 20 C 22 5, 26 35, 34 18" 
            stroke="url(#footer-logo-grad)" 
            stroke-width="2.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          />
        </svg>
        <span class="brand-sub">winada <span class="sub-product">controller</span></span>
      </div>
      <div class="footer-right">
        &copy; {new Date().getFullYear()} Winada. Built for simple, reliable multi-room music control.
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-top: 48px;
    padding-bottom: 60px;
    background: transparent;
  }

  .footer-console-plate {
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-top: 28px;
  }

  .logo-mark {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-sub {
    font-weight: 700;
    color: var(--color-text);
  }

  .sub-product {
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .footer-right {
    font-weight: 400;
  }

  @media (max-width: 600px) {
    .footer-console-plate {
      flex-direction: column;
      gap: 16px;
      text-align: center;
      padding-top: 24px;
    }
  }
</style>
