---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="brand-name">WINADA</span>
        <span class="brand-tagline">Premium Audio Solutions.</span>
      </div>
      
      <div class="footer-links">
        <a href="#">Services</a>
        <a href="#">Case Studies</a>
        <a href="#">Partner with Us</a>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="footer-copyright">
        Copyright &copy; {new Date().getFullYear()} Winada Inc. All rights reserved.
      </div>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <span class="sep">|</span>
        <a href="#">Terms of Use</a>
        <span class="sep">|</span>
        <a href="#">Sales Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: rgba(10, 10, 15, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 40px 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  @media (max-width: 600px) {
    .footer-top {
      flex-direction: column;
      gap: 24px;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand-name {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
  }

  .brand-tagline {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-links {
    display: flex;
    gap: 32px;
  }

  .footer-links a {
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-legal a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer-legal a:hover {
    text-decoration: underline;
    color: var(--color-text-primary);
  }
</style>
